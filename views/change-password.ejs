<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Change Password - DOJ</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
</head>
<body>
  <nav class="navbar">
    <div class="nav-left">
      <a href="/" class="logo">DOJ</a>
      <a href="/problems" class="nav-link">Problems</a>
      <a href="/organizations" class="nav-link">Organizations</a>
    </div>
    <div class="nav-right">
      <% if (user) { %>
        <a href="/problems/create" class="btn-register">+ Create</a>
        <a href="/profile/<%= user.username %>" class="nav-username"><%= user.username %></a>
        <a href="/logout" class="btn-logout">Logout</a>
      <% } %>
    </div>
  </nav>

  <div class="auth-container">
    <div class="auth-box">
      <h2>Change Password</h2>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="error-msg"><%= error %></div>
      <% } %>
      <% if (typeof success !== 'undefined' && success) { %>
        <div style="background-color:#1a3a2a; border:1px solid #00e5a0; color:#00e5a0; padding:10px 14px; border-radius:4px; margin-bottom:20px; font-size:14px;"><%= success %></div>
      <% } %>
      <form action="/change-password" method="POST">
        <div class="form-group">
          <label>Current Password</label>
          <div class="password-wrapper">
            <input type="password" name="currentPassword" id="currentPassword" placeholder="Enter current password" required />
            <span class="toggle-password" onclick="togglePassword('currentPassword', this)">Show</span>
          </div>
        </div>
        <div class="form-group">
          <label>New Password</label>
          <div class="password-wrapper">
            <input type="password" name="newPassword" id="newPassword" placeholder="Enter new password" required />
            <span class="toggle-password" onclick="togglePassword('newPassword', this)">Show</span>
          </div>
        </div>
        <div class="form-group">
          <label>Confirm New Password</label>
          <div class="password-wrapper">
            <input type="password" name="confirmPassword" id="confirmPassword" placeholder="Re-enter new password" required />
            <span class="toggle-password" onclick="togglePassword('confirmPassword', this)">Show</span>
          </div>
        </div>
        <button type="submit" class="btn-submit">Change Password</button>
      </form>
      <p class="auth-switch"><a href="/profile/<%= user.username %>">Back to Profile</a></p>
    </div>
  </div>

  <script>
    function togglePassword(id, el) {
      const input = document.getElementById(id);
      if (input.type === 'password') {
        input.type = 'text';
        el.textContent = 'Hide';
      } else {
        input.type = 'password';
        el.textContent = 'Show';
      }
    }
  </script>
</body>
</html>