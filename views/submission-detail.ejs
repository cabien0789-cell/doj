<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Submission Detail - DOJ</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/codemirror.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/theme/dracula.min.css">
</head>
<body>
  <nav class="navbar">
    <div class="nav-left">
      <a href="/" class="logo">DOJ</a>
      <a href="/problems" class="nav-link">Problems</a>
      <a href="/organizations" class="nav-link">Organizations</a>
      <a href="/leaderboard" class="nav-link">Leaderboard</a>
      <% if (user && user.role === 'admin') { %>
        <a href="/admin" class="nav-link">Admin</a>
      <% } %>
    </div>
    <div class="nav-right">
      <% if (user) { %>
        <a href="/notifications" class="notif-btn">
          🔔 <span class="notif-badge" id="notifBadge" style="display:none;">0</span>
        </a>
        <a href="/profile/<%= user.username %>" class="nav-username"><%= user.username %></a>
        <a href="/logout" class="btn-logout">Logout</a>
      <% } %>
    </div>
  </nav>

  <div class="result-container">
    <h2>Submission Detail</h2>

    <div class="result-box">
      <div class="result-status verdict-<%= submission.verdict.replace(/\s+/g,'').toLowerCase() %>">
        <%= submission.verdict %>
      </div>
      <p class="result-score"><%= submission.passedCount %> / <%= submission.total %> test cases passed</p>
      <p style="color:#7a9ab0; font-size:13px; margin-top:8px;">
        <%= submission.language.toUpperCase() %> &nbsp;·&nbsp;
        <%= new Date(submission.submittedAt).toLocaleString('en-GB', { hour12: false }) %> &nbsp;·&nbsp;
        <a href="/problems/<%= submission.problemId %>" style="color:#00e5a0; text-decoration:none;"><%= submission.problemTitle %></a>
        <% if (submission.execTime !== undefined) { %>
          &nbsp;·&nbsp; ⏱ <strong style="color:#ffffff;"><%= submission.execTime %>ms</strong>
        <% } %>
      </p>
    </div>

    <div style="font-size:13px; font-weight:600; color:#7a9ab0; text-transform:uppercase; letter-spacing:1px; margin-bottom:12px;">Test Cases</div>
    <div style="display:grid; grid-template-columns:repeat(3, minmax(0,1fr)); gap:8px; margin-bottom:24px;">
      <% for (let i = 0; i < submission.total; i++) { %>
        <%
          const verdict = submission.verdict;
          let borderColor = '#2a3e4e';
          let textColor = '#7a9ab0';
          let statusText = '—';
          if (i < submission.passedCount) {
            borderColor = '#00e5a0'; textColor = '#00e5a0'; statusText = 'AC';
          } else if (verdict === 'Compilation Error') {
            borderColor = '#38bdf8'; textColor = '#38bdf8'; statusText = 'CE';
          } else if (verdict === 'Time Limit Exceeded') {
            borderColor = '#f5a623'; textColor = '#f5a623'; statusText = 'TLE';
          } else if (verdict === 'Runtime Error') {
            borderColor = '#f87171'; textColor = '#f87171'; statusText = 'RE';
          } else {
            borderColor = '#ff4444'; textColor = '#ff4444'; statusText = 'WA';
          }
        %>
        <div style="background:#141e26; border:1px solid <%= borderColor %>; border-radius:6px; padding:10px 14px; display:flex; justify-content:space-between; align-items:center;">
          <span style="font-size:13px; color:#7a9ab0;">Test #<%= i + 1 %></span>
          <span style="font-size:12px; font-weight:600; color:<%= textColor %>;"><%= statusText %></span>
        </div>
      <% } %>
    </div>

    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
      <span style="font-size:13px; font-weight:600; color:#7a9ab0; text-transform:uppercase; letter-spacing:1px;">Your Code</span>
      <button id="copyBtn" onclick="copyCode()" style="background:transparent; border:1px solid #2a3e4e; color:#7a9ab0; padding:6px 14px; border-radius:4px; cursor:pointer; font-size:13px; transition:all 0.2s;">📋 Copy Code</button>
    </div>
    <div style="border:1px solid #2a3e4e; border-radius:4px; overflow:hidden; margin-bottom:24px;">
      <textarea id="codeView"><%= submission.code %></textarea>
    </div>

    <a href="/problems/<%= submission.problemId %>" class="btn-submit" style="display:inline-block; text-decoration:none;">Back to Problem</a>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/codemirror.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/mode/clike/clike.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/mode/python/python.min.js"></script>
  <script>
    const modeMap = { cpp: 'text/x-c++src', c: 'text/x-csrc', python: 'text/x-python' };
    const editor = CodeMirror.fromTextArea(document.getElementById('codeView'), {
      mode: modeMap['<%= submission.language %>'] || 'text/x-c++src',
      theme: 'dracula', lineNumbers: true, readOnly: true
    });
    editor.setSize('100%', '400px');

    function copyCode() {
      navigator.clipboard.writeText(editor.getValue()).then(() => {
        const btn = document.getElementById('copyBtn');
        btn.textContent = '✓ Copied!';
        btn.style.color = '#00e5a0';
        btn.style.borderColor = '#00e5a0';
        setTimeout(() => {
          btn.textContent = '📋 Copy Code';
          btn.style.color = '#7a9ab0';
          btn.style.borderColor = '#2a3e4e';
        }, 2000);
      });
    }

    fetch('/notifications/count').then(r => r.json()).then(data => {
      if (data.count > 0) {
        const badge = document.getElementById('notifBadge');
        badge.textContent = data.count;
        badge.style.display = 'inline-block';
      }
    });
  </script>
</body>
</html>