<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Organizations - DOJ</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
</head>
<body>
  <nav class="navbar">
    <div class="nav-left">
      <a href="/" class="logo">DOJ</a>
      <a href="/problems" class="nav-link">Problems</a>
      <a href="/organizations" class="nav-link active">Organizations</a>
      <a href="/leaderboard" class="nav-link">Leaderboard</a>
      <% if (user && user.role === 'admin') { %>
        <a href="/admin" class="nav-link">Admin</a>
      <% } %>
    </div>
    <div class="nav-right">
      <% if (user) { %>
        <a href="/notifications" class="notif-btn">
          🔔 <span class="notif-badge" id="notifBadge" style="display:none;">0</span>
        </a>
        <a href="/profile/<%= user.username %>" class="nav-username"><%= user.username %></a>
        <a href="/logout" class="btn-logout">Logout</a>
      <% } else { %>
        <a href="/login" class="btn-login">Log In</a>
        <a href="/register" class="btn-register">Sign Up</a>
      <% } %>
    </div>
  </nav>

  <div class="problems-container">
    <div class="problems-header" style="display:flex; justify-content:space-between; align-items:center;">
      <h2>Organizations</h2>
      <% if (user && (user.role === 'org' || user.role === 'admin')) { %>
        <a href="/organizations/create" class="btn-register" style="text-decoration:none;">+ Create Organization</a>
      <% } %>
    </div>

    <div style="display:flex; gap:12px; margin-bottom:20px; flex-wrap:wrap;">
      <input type="text" id="searchInput" placeholder="Search organizations..." class="filter-input" style="flex:1; min-width:200px;" />
      <% if (user) { %>
        <div style="display:flex; gap:8px;">
          <button onclick="showTab('all')" id="tabAll" class="tab-btn tab-active">All</button>
          <button onclick="showTab('mine')" id="tabMine" class="tab-btn">My Organizations</button>
        </div>
      <% } %>
    </div>

    <div id="orgList">
      <% if (organizations.length === 0) { %>
        <div style="text-align:center; color:#7a9ab0; padding:60px 0;">No organizations yet.</div>
      <% } else { %>
        <% organizations.forEach(org => { %>
          <div class="org-card"
            data-name="<%= org.name.toLowerCase() %>"
            data-member="<%= user && org.members && org.members.includes(user.username) ? 'true' : 'false' %>">
            <div style="display:flex; justify-content:space-between; align-items:flex-start;">
              <div>
                <div style="display:flex; align-items:center; gap:8px;">
                  <a href="/organizations/<%= org.id %>" style="font-size:18px; font-weight:700; color:#ffffff; text-decoration:none;"><%= org.name %></a>
                  <% if (org.hidden) { %>
                    <span style="color:#f5a623; font-size:11px; padding:2px 8px; border:1px solid #f5a623; border-radius:20px;">🔒 Hidden</span>
                  <% } else { %>
                    <span style="color:#7a9ab0; font-size:11px; padding:2px 8px; border:1px solid #2a3e4e; border-radius:20px;">🌐 Public</span>
                  <% } %>
                </div>
                <p style="color:#7a9ab0; font-size:13px; margin:6px 0 0;">Owner: <strong style="color:#e0eaf0;"><%= org.owner %></strong> · <%= org.members ? org.members.length : 0 %> members</p>
                <% if (org.description) { %>
                  <p style="color:#7a9ab0; font-size:13px; margin:6px 0 0;"><%= org.description %></p>
                <% } %>
              </div>
              <% if (user) { %>
                <% if (org.owner === user.username) { %>
                  <span style="color:#00e5a0; font-size:12px; font-weight:600; padding:4px 10px; border:1px solid #00e5a0; border-radius:20px;">Owner</span>
                <% } else if (org.members && org.members.includes(user.username)) { %>
                  <span style="color:#7a9ab0; font-size:12px; font-weight:600; padding:4px 10px; border:1px solid #2a3e4e; border-radius:20px;">Member</span>
                <% } else if (org.pendingMembers && org.pendingMembers.includes(user.username)) { %>
                  <span style="color:#f5a623; font-size:12px; font-weight:600; padding:4px 10px; border:1px solid #f5a623; border-radius:20px;">Pending</span>
                <% } else { %>
                  <form action="/organizations/<%= org.id %>/request" method="POST">
                    <button type="submit" class="btn-join">Request to Join</button>
                  </form>
                <% } %>
              <% } %>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>

    <div id="noResults" style="display:none; text-align:center; color:#7a9ab0; padding:40px;">No organizations match your search.</div>
  </div>

  <script>
    let currentTab = 'all';

    function showTab(tab) {
      currentTab = tab;
      document.getElementById('tabAll').className = tab === 'all' ? 'tab-btn tab-active' : 'tab-btn';
      document.getElementById('tabMine').className = tab === 'mine' ? 'tab-btn tab-active' : 'tab-btn';
      filterOrgs();
    }

    function filterOrgs() {
      const search = document.getElementById('searchInput').value.toLowerCase();
      const cards = document.querySelectorAll('.org-card');
      let visible = 0;
      cards.forEach(card => {
        const name = card.dataset.name;
        const isMember = card.dataset.member === 'true';
        const matchSearch = name.includes(search);
        const matchTab = currentTab === 'all' || isMember;
        if (matchSearch && matchTab) { card.style.display = ''; visible++; }
        else card.style.display = 'none';
      });
      document.getElementById('noResults').style.display = visible === 0 ? 'block' : 'none';
    }

    document.getElementById('searchInput').addEventListener('input', filterOrgs);

    <% if (user) { %>
    fetch('/notifications/count').then(r => r.json()).then(data => {
      if (data.count > 0) {
        const badge = document.getElementById('notifBadge');
        badge.textContent = data.count;
        badge.style.display = 'inline-block';
      }
    });
    <% } %>
  </script>
</body>
</html>