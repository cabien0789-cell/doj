<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Organizations - DOJ</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="nav-left">
      <a href="/" class="logo">DOJ</a>
      <a href="/problems" class="nav-link">Problems</a>
      <a href="/organizations" class="nav-link active">Organizations</a>
    </div>
    <div class="nav-right">
      <% if (user) { %>
        <a href="/problems/create" class="btn-register">+ Create</a>
        <span class="nav-username"><%= user.username %></span>
        <a href="/logout" class="btn-logout">Logout</a>
      <% } else { %>
        <a href="/login" class="btn-login">Log In</a>
        <a href="/register" class="btn-register">Sign Up</a>
      <% } %>
    </div>
  </nav>

  <div class="problems-container">
    <div class="problems-header">
      <h2>Organizations</h2>
      <% if (user) { %>
        <a href="/organizations/create" class="btn-register">+ Create Organization</a>
      <% } %>
    </div>

    <table class="problems-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Name</th>
          <th>Members</th>
          <th>Owner</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% if (organizations.length === 0) { %>
          <tr>
            <td colspan="5" class="no-problems">No organizations yet.</td>
          </tr>
        <% } else { %>
          <% organizations.forEach((org, index) => { %>
            <tr>
              <td><%= index + 1 %></td>
              <td><a href="/organizations/<%= org.id %>"><%= org.name %></a></td>
              <td><%= org.members.length %></td>
              <td><%= org.owner %></td>
              <td>
                <% if (user) { %>
                  <% if (org.members.includes(user.username)) { %>
                    <a href="/organizations/<%= org.id %>/leave" class="btn-leave">Leave</a>
                  <% } else { %>
                    <a href="/organizations/<%= org.id %>/join" class="btn-join">Join</a>
                  <% } %>
                <% } %>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</body>
</html>