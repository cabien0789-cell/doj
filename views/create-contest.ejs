<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create Contest - DOJ</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
</head>
<body>
  <nav class="navbar">
    <div class="nav-left">
      <a href="/" class="logo">DOJ</a>
      <a href="/problems" class="nav-link">Problems</a>
      <a href="/organizations" class="nav-link">Organizations</a>
      <a href="/leaderboard" class="nav-link">Leaderboard</a>
      <% if (user && user.role === 'admin') { %>
        <a href="/admin" class="nav-link">Admin</a>
      <% } %>
    </div>
    <div class="nav-right">
      <a href="/notifications" class="notif-btn">
        🔔 <span class="notif-badge" id="notifBadge" style="display:none;">0</span>
      </a>
      <a href="/profile/<%= user.username %>" class="nav-username"><%= user.username %></a>
      <a href="/logout" class="btn-logout">Logout</a>
    </div>
  </nav>

  <div class="create-container">
    <h2>Create Contest</h2>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="error-msg"><%= error %></div>
    <% } %>
    <form action="/organizations/<%= orgId %>/contests/create" method="POST" id="contestForm">

      <div class="form-group">
        <label>Contest Name</label>
        <input type="text" name="name" placeholder="Enter contest name" required />
      </div>

      <div class="form-group">
        <label>Visibility</label>
        <div style="display:flex; gap:12px; margin-top:8px; flex-wrap:wrap;">
          <label class="visibility-option selected-public" id="opt-public">
            <input type="radio" name="visibility" value="public" checked onchange="updateVisibility()">
            <div>
              <div style="color:#00e5a0; font-weight:600; font-size:14px;">🌐 Public</div>
              <div style="color:#a0a0b0; font-size:12px; margin-top:2px;">Anyone can view and participate</div>
            </div>
          </label>
          <label class="visibility-option" id="opt-private">
            <input type="radio" name="visibility" value="private" onchange="updateVisibility()">
            <div>
              <div style="color:#f5a623; font-weight:600; font-size:14px;">🔒 Private</div>
              <div style="color:#a0a0b0; font-size:12px; margin-top:2px;">Members only</div>
            </div>
          </label>
        </div>
      </div>

      <div class="form-group">
        <label>Timezone</label>
        <select name="timezone" id="timezoneSelect" onchange="updateTimePlaceholders()">
          <option value="UTC">UTC (Coordinated Universal Time)</option>
          <option value="Vietnam">Vietnam (UTC+7)</option>
        </select>
      </div>

      <div class="form-group">
        <label class="tag-checkbox" style="display:inline-flex;">
          <input type="checkbox" name="noTimeLimit" id="noTimeLimit" onchange="toggleTimeLimit()">
          <span>No time limit (contest always Live)</span>
        </label>
      </div>

      <div id="timeLimitFields">
        <div class="form-group">
          <label>Start Time <span id="tzLabel" style="color:#a0a0b0; font-size:12px;">(UTC — enter time in UTC)</span></label>
          <div style="display:flex; gap:8px; align-items:center; flex-wrap:wrap;">
            <input type="date" id="startDate" style="flex:1; min-width:140px;" required />
            <div style="display:flex; gap:4px; align-items:center;">
              <input type="number" id="startHour" min="0" max="23" placeholder="HH" style="width:64px; text-align:center;" required />
              <span style="color:#a0a0b0;">:</span>
              <input type="number" id="startMinute" min="0" max="59" placeholder="MM" style="width:64px; text-align:center;" required />
            </div>
          </div>
          <input type="hidden" name="startTime" id="startTime" />
        </div>
        <div class="form-group">
          <label>End Time <span id="tzLabel2" style="color:#a0a0b0; font-size:12px;">(UTC — enter time in UTC)</span></label>
          <div style="display:flex; gap:8px; align-items:center; flex-wrap:wrap;">
            <input type="date" id="endDate" style="flex:1; min-width:140px;" required />
            <div style="display:flex; gap:4px; align-items:center;">
              <input type="number" id="endHour" min="0" max="23" placeholder="HH" style="width:64px; text-align:center;" required />
              <span style="color:#a0a0b0;">:</span>
              <input type="number" id="endMinute" min="0" max="59" placeholder="MM" style="width:64px; text-align:center;" required />
            </div>
          </div>
          <input type="hidden" name="endTime" id="endTime" />
        </div>
        <div id="tzHint" style="background:#1a1a2e; border:1px solid #2a2a4a; border-radius:6px; padding:10px 14px; margin-bottom:16px; color:#a0a0b0; font-size:13px;">
          💡 Current time: <strong id="currentTimeDisplay" style="color:#ffffff;"></strong>
        </div>
      </div>

      <div class="form-group">
        <label>Problems</label>
        <div style="margin-bottom:8px;">
          <input type="text" id="problemSearchInput" placeholder="Search your problems..." class="filter-input" oninput="searchProblems()" />
        </div>
        <div id="problemSearchResults" style="background:#0f0f23; border:1px solid #2a2a4a; border-radius:6px; max-height:200px; overflow-y:auto; display:none; margin-bottom:8px;"></div>
        <div id="selectedProblems" style="display:flex; flex-direction:column; gap:6px;"></div>
        <div id="problemIdsContainer"></div>
      </div>

      <button type="submit" class="btn-submit" onclick="return buildDateTime()">Create Contest</button>
    </form>
  </div>

  <script>
    const selectedProblemIds = new Set();
    const SERVER_UTC = '<%= serverTime.utc %>';
    const SERVER_VN = '<%= serverTime.vietnam %>';

    function pad(n) { return String(n).padStart(2, '0'); }

    function buildDateTime() {
      const noLimit = document.getElementById('noTimeLimit').checked;
      if (noLimit) return true;

      const sd = document.getElementById('startDate').value;
      const sh = document.getElementById('startHour').value;
      const sm = document.getElementById('startMinute').value;
      const ed = document.getElementById('endDate').value;
      const eh = document.getElementById('endHour').value;
      const em = document.getElementById('endMinute').value;

      if (!sd || sh === '' || sm === '' || !ed || eh === '' || em === '') {
        alert('Please fill in all date and time fields.');
        return false;
      }

      document.getElementById('startTime').value = sd + 'T' + pad(sh) + ':' + pad(sm);
      document.getElementById('endTime').value = ed + 'T' + pad(eh) + ':' + pad(em);
      return true;
    }

    function updateVisibility() {
      const isPublic = document.querySelector('input[name="visibility"][value="public"]').checked;
      document.getElementById('opt-public').className = isPublic ? 'visibility-option selected-public' : 'visibility-option';
      document.getElementById('opt-private').className = !isPublic ? 'visibility-option selected-private' : 'visibility-option';
    }

    function toggleTimeLimit() {
      const checked = document.getElementById('noTimeLimit').checked;
      document.getElementById('timeLimitFields').style.display = checked ? 'none' : 'block';
      const timeInputs = ['startDate', 'startHour', 'startMinute', 'endDate', 'endHour', 'endMinute'];
      timeInputs.forEach(id => {
        const el = document.getElementById(id);
        if (el) {
          if (checked) el.removeAttribute('required');
          else el.setAttribute('required', '');
        }
      });
    }

    function updateTimePlaceholders() {
      const tz = document.getElementById('timezoneSelect').value;
      const isVietnam = tz === 'Vietnam';
      const label = isVietnam ? '(Vietnam UTC+7 — enter time in Vietnam time)' : '(UTC — enter time in UTC)';
      document.getElementById('tzLabel').textContent = label;
      document.getElementById('tzLabel2').textContent = label;
      updateCurrentTime();
    }

    function updateCurrentTime() {
      const tz = document.getElementById('timezoneSelect').value;
      document.getElementById('currentTimeDisplay').textContent = tz === 'Vietnam' ? SERVER_VN : SERVER_UTC;
    }

    updateCurrentTime();

    async function searchProblems() {
      const q = document.getElementById('problemSearchInput').value.trim();
      const resultsDiv = document.getElementById('problemSearchResults');
      if (q.length === 0) { resultsDiv.style.display = 'none'; return; }

      const res = await fetch('/api/my-problems?q=' + encodeURIComponent(q));
      const problems = await res.json();

      if (problems.length === 0) {
        resultsDiv.innerHTML = '<div style="padding:12px 16px; color:#a0a0b0; font-size:13px;">No problems found.</div>';
      } else {
        resultsDiv.innerHTML = problems.map(p => `
          <div style="padding:10px 16px; display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid #2a2a4a; cursor:pointer;" onmouseenter="this.style.background='#1a1a2e'" onmouseleave="this.style.background=''" onclick="addProblem('${p.id}', '${p.title.replace(/'/g, "\\'")}', '${p.difficulty}')">
            <span style="color:#ffffff; font-size:14px;">${p.title}</span>
            <span class="difficulty-${p.difficulty.toLowerCase()}" style="font-size:12px;">${p.difficulty}</span>
          </div>
        `).join('');
      }
      resultsDiv.style.display = 'block';
    }

    function addProblem(id, title, difficulty) {
      if (selectedProblemIds.has(id)) return;
      selectedProblemIds.add(id);

      const container = document.getElementById('selectedProblems');
      const div = document.createElement('div');
      div.id = 'selected-' + id;
      div.style.cssText = 'display:flex; justify-content:space-between; align-items:center; background:#0f0f23; border:1px solid #2a2a4a; border-radius:6px; padding:10px 14px;';
      div.innerHTML = `
        <span style="color:#ffffff; font-size:14px;">${title} <span class="difficulty-${difficulty.toLowerCase()}" style="font-size:12px;">(${difficulty})</span></span>
        <button type="button" onclick="removeProblem('${id}')" style="background:transparent; border:1px solid #ff4444; color:#ff4444; padding:4px 10px; border-radius:4px; cursor:pointer; font-size:12px;">Remove</button>
      `;
      container.appendChild(div);

      const input = document.createElement('input');
      input.type = 'hidden';
      input.name = 'problemIds[]';
      input.value = id;
      input.id = 'input-' + id;
      document.getElementById('problemIdsContainer').appendChild(input);

      document.getElementById('problemSearchInput').value = '';
      document.getElementById('problemSearchResults').style.display = 'none';
    }

    function removeProblem(id) {
      selectedProblemIds.delete(id);
      const el = document.getElementById('selected-' + id);
      if (el) el.remove();
      const input = document.getElementById('input-' + id);
      if (input) input.remove();
    }

    fetch('/notifications/count').then(r => r.json()).then(data => {
      if (data.count > 0) {
        const badge = document.getElementById('notifBadge');
        badge.textContent = data.count;
        badge.style.display = 'inline-block';
      }
    });
  </script>
</body>
</html>