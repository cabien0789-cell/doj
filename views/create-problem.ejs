<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create Problem - DOJ</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
</head>
<body>
  <nav class="navbar">
    <div class="nav-left">
      <a href="/" class="logo">DOJ</a>
      <a href="/problems" class="nav-link">Problems</a>
      <a href="/organizations" class="nav-link">Organizations</a>
      <a href="/leaderboard" class="nav-link">Leaderboard</a>
    </div>
    <div class="nav-right">
      <a href="/problems/create" class="btn-register">+ Create</a>
      <a href="/profile/<%= user.username %>" class="nav-username"><%= user.username %></a>
      <a href="/logout" class="btn-logout">Logout</a>
    </div>
  </nav>

  <div class="create-container">
    <h2>Create Problem</h2>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="error-msg"><%= error %></div>
    <% } %>
    <form action="/problems/create" method="POST" id="problemForm" enctype="multipart/form-data">
      <div class="form-group">
        <label>Title</label>
        <input type="text" name="title" placeholder="Problem title" required />
      </div>
      <div class="form-group">
        <label>Difficulty</label>
        <select name="difficulty">
          <option value="Easy">Easy</option>
          <option value="Medium">Medium</option>
          <option value="Hard">Hard</option>
        </select>
      </div>
      <div class="form-group">
        <label>Tags</label>
        <div class="tags-grid">
          <% ['Arrays', 'Strings', 'Math', 'Sorting', 'Searching', 'Dynamic Programming', 'Greedy', 'Graph', 'Tree', 'Recursion', 'Stack', 'Queue', 'Linked List', 'Binary Search', 'Two Pointers', 'Bit Manipulation', 'Geometry', 'Number Theory'].forEach(tag => { %>
            <label class="tag-checkbox">
              <input type="checkbox" name="tags[]" value="<%= tag %>">
              <span><%= tag %></span>
            </label>
          <% }) %>
        </div>
      </div>
      <div class="form-group">
        <label>Time Limit (seconds)</label>
        <select name="timeLimit">
          <option value="1">1 second</option>
          <option value="2" selected>2 seconds</option>
          <option value="3">3 seconds</option>
          <option value="5">5 seconds</option>
          <option value="10">10 seconds</option>
        </select>
      </div>
      <div class="form-group">
        <label>Problem Statement</label>
        <textarea name="statement" rows="8" placeholder="Describe the problem..." required></textarea>
      </div>
      <div class="form-group">
        <label>Input Format</label>
        <textarea name="inputFormat" rows="3" placeholder="Describe the input format..." required></textarea>
      </div>
      <div class="form-group">
        <label>Output Format</label>
        <textarea name="outputFormat" rows="3" placeholder="Describe the output format..." required></textarea>
      </div>
      <div class="form-group">
        <label>Constraints</label>
        <textarea name="constraints" rows="3" placeholder="e.g. 1 ≤ N ≤ 10^5"></textarea>
      </div>
      <div class="form-group">
        <label>Explanation</label>
        <textarea name="explanation" rows="4" placeholder="Explain the sample test cases..."></textarea>
      </div>

      <div class="testcases-section">
        <h3>Sample Test Cases</h3>
        <div id="sampleTestcases">
          <div class="testcase">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
              <span style="color:#a0a0b0; font-size:13px;">Sample #1</span>
              <button type="button" class="btn-remove-tc" onclick="removeTestcase(this, 'sample')">Remove</button>
            </div>
            <div class="form-group">
              <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
                <label style="margin:0;">Input</label>
                <label class="upload-btn"><input type="file" accept=".txt" onchange="handleFileUpload(this, 'sampleInput', 0)"> 📁 Upload .txt</label>
              </div>
              <div class="tc-file-info" id="sampleInputFileInfo-0" style="display:none; background:#1a1a2e; border:1px solid #00e5a0; border-radius:4px; padding:8px 12px; margin-bottom:6px; font-size:13px; color:#00e5a0;"></div>
              <textarea name="sampleInput_0" rows="3" placeholder="Sample input..." id="sampleInputText-0"></textarea>
              <input type="file" name="sampleInputFile_0" accept=".txt" id="sampleInputFile-0" style="display:none">
            </div>
            <div class="form-group">
              <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
                <label style="margin:0;">Output</label>
                <label class="upload-btn"><input type="file" accept=".txt" onchange="handleFileUpload(this, 'sampleOutput', 0)"> 📁 Upload .txt</label>
              </div>
              <div class="tc-file-info" id="sampleOutputFileInfo-0" style="display:none; background:#1a1a2e; border:1px solid #00e5a0; border-radius:4px; padding:8px 12px; margin-bottom:6px; font-size:13px; color:#00e5a0;"></div>
              <textarea name="sampleOutput_0" rows="3" placeholder="Sample output..." id="sampleOutputText-0"></textarea>
              <input type="file" name="sampleOutputFile_0" accept=".txt" id="sampleOutputFile-0" style="display:none">
            </div>
          </div>
        </div>
        <button type="button" class="btn-add-tc" onclick="addTestcase('sample')">+ Add Sample Test Case</button>
      </div>

      <div class="testcases-section">
        <h3>Hidden Test Cases</h3>
        <div id="hiddenTestcases">
          <div class="testcase">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
              <span style="color:#a0a0b0; font-size:13px;">Hidden #1</span>
              <button type="button" class="btn-remove-tc" onclick="removeTestcase(this, 'hidden')">Remove</button>
            </div>
            <div class="form-group">
              <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
                <label style="margin:0;">Input</label>
                <label class="upload-btn"><input type="file" accept=".txt" onchange="handleFileUpload(this, 'hiddenInput', 0)"> 📁 Upload .txt</label>
              </div>
              <div class="tc-file-info" id="hiddenInputFileInfo-0" style="display:none; background:#1a1a2e; border:1px solid #00e5a0; border-radius:4px; padding:8px 12px; margin-bottom:6px; font-size:13px; color:#00e5a0;"></div>
              <textarea name="hiddenInput_0" rows="3" placeholder="Hidden input..." id="hiddenInputText-0"></textarea>
              <input type="file" name="hiddenInputFile_0" accept=".txt" id="hiddenInputFile-0" style="display:none">
            </div>
            <div class="form-group">
              <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
                <label style="margin:0;">Output</label>
                <label class="upload-btn"><input type="file" accept=".txt" onchange="handleFileUpload(this, 'hiddenOutput', 0)"> 📁 Upload .txt</label>
              </div>
              <div class="tc-file-info" id="hiddenOutputFileInfo-0" style="display:none; background:#1a1a2e; border:1px solid #00e5a0; border-radius:4px; padding:8px 12px; margin-bottom:6px; font-size:13px; color:#00e5a0;"></div>
              <textarea name="hiddenOutput_0" rows="3" placeholder="Hidden output..." id="hiddenOutputText-0"></textarea>
              <input type="file" name="hiddenOutputFile_0" accept=".txt" id="hiddenOutputFile-0" style="display:none">
            </div>
          </div>
        </div>
        <button type="button" class="btn-add-tc" onclick="addTestcase('hidden')">+ Add Hidden Test Case</button>
      </div>

      <button type="submit" class="btn-submit">Create Problem</button>
    </form>
  </div>

  <script>
    const FILE_SIZE_LIMIT = 10 * 1024;
    let sampleCount = 1;
    let hiddenCount = 1;

    function handleFileUpload(input, fieldName, index) {
      const file = input.files[0];
      if (!file) return;

      const infoEl = document.getElementById(fieldName + 'FileInfo-' + index);
      const textEl = document.getElementById(fieldName + 'Text-' + index);
      const fileInput = document.getElementById(fieldName + 'File-' + index);

      const dt = new DataTransfer();
      dt.items.add(file);
      fileInput.files = dt.files;

      if (file.size > FILE_SIZE_LIMIT) {
        textEl.style.display = 'none';
        textEl.value = '';
        textEl.removeAttribute('name');
        infoEl.style.display = 'block';
        infoEl.textContent = '📄 ' + file.name + ' (' + (file.size / 1024).toFixed(1) + ' KB) — file uploaded';
      } else {
        const reader = new FileReader();
        reader.onload = function(e) {
          textEl.style.display = '';
          textEl.setAttribute('name', fieldName + '_' + index);
          textEl.value = e.target.result;
          infoEl.style.display = 'none';
          fileInput.value = '';
        };
        reader.readAsText(file);
      }
    }

    function addTestcase(type) {
      const container = document.getElementById(type + 'Testcases');
      const index = type === 'sample' ? sampleCount++ : hiddenCount++;
      const label = type === 'sample' ? 'Sample' : 'Hidden';
      const fieldPrefix = type === 'sample' ? 'sample' : 'hidden';

      const div = document.createElement('div');
      div.className = 'testcase';
      div.innerHTML = `
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
          <span style="color:#a0a0b0; font-size:13px;">${label} #${index + 1}</span>
          <button type="button" class="btn-remove-tc" onclick="removeTestcase(this, '${type}')">Remove</button>
        </div>
        <div class="form-group">
          <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
            <label style="margin:0;">Input</label>
            <label class="upload-btn"><input type="file" accept=".txt" onchange="handleFileUpload(this, '${fieldPrefix}Input', ${index})"> 📁 Upload .txt</label>
          </div>
          <div class="tc-file-info" id="${fieldPrefix}InputFileInfo-${index}" style="display:none; background:#1a1a2e; border:1px solid #00e5a0; border-radius:4px; padding:8px 12px; margin-bottom:6px; font-size:13px; color:#00e5a0;"></div>
          <textarea name="${fieldPrefix}Input_${index}" rows="3" placeholder="${label} input..." id="${fieldPrefix}InputText-${index}"></textarea>
          <input type="file" name="${fieldPrefix}InputFile_${index}" accept=".txt" id="${fieldPrefix}InputFile-${index}" style="display:none">
        </div>
        <div class="form-group">
          <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
            <label style="margin:0;">Output</label>
            <label class="upload-btn"><input type="file" accept=".txt" onchange="handleFileUpload(this, '${fieldPrefix}Output', ${index})"> 📁 Upload .txt</label>
          </div>
          <div class="tc-file-info" id="${fieldPrefix}OutputFileInfo-${index}" style="display:none; background:#1a1a2e; border:1px solid #00e5a0; border-radius:4px; padding:8px 12px; margin-bottom:6px; font-size:13px; color:#00e5a0;"></div>
          <textarea name="${fieldPrefix}Output_${index}" rows="3" placeholder="${label} output..." id="${fieldPrefix}OutputText-${index}"></textarea>
          <input type="file" name="${fieldPrefix}OutputFile_${index}" accept=".txt" id="${fieldPrefix}OutputFile-${index}" style="display:none">
        </div>
      `;
      container.appendChild(div);
      renumberTestcases(type);
    }

    function removeTestcase(btn, type) {
      const container = document.getElementById(type + 'Testcases');
      if (container.children.length <= 1) return;
      btn.closest('.testcase').remove();
      renumberTestcases(type);
    }

    function renumberTestcases(type) {
      const container = document.getElementById(type + 'Testcases');
      const label = type === 'sample' ? 'Sample' : 'Hidden';
      Array.from(container.children).forEach((div, i) => {
        const span = div.querySelector('span');
        if (span) span.textContent = `${label} #${i + 1}`;
      });
    }
  </script>
</body>
</html>