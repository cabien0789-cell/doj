<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Contest - DOJ</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
</head>
<body>
  <nav class="navbar">
    <div class="nav-left">
      <a href="/" class="logo">DOJ</a>
      <a href="/problems" class="nav-link">Problems</a>
      <a href="/organizations" class="nav-link">Organizations</a>
      <a href="/leaderboard" class="nav-link">Leaderboard</a>
      <% if (user && user.role === 'admin') { %>
        <a href="/admin" class="nav-link">Admin</a>
      <% } %>
    </div>
    <div class="nav-right">
      <a href="/notifications" class="notif-btn">
        🔔 <span class="notif-badge" id="notifBadge" style="display:none;">0</span>
      </a>
      <a href="/profile/<%= user.username %>" class="nav-username"><%= user.username %></a>
      <a href="/logout" class="btn-logout">Logout</a>
    </div>
  </nav>

  <div class="create-container">
    <h2>Edit Contest</h2>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="error-msg"><%= error %></div>
    <% } %>
    <form action="/contests/<%= contest.id %>/edit" method="POST" id="contestForm">

      <div class="form-group">
        <label>Contest Name</label>
        <input type="text" name="name" value="<%= contest.name %>" required />
      </div>

      <div class="form-group">
        <label>Visibility</label>
        <div style="display:flex; gap:12px; margin-top:8px; flex-wrap:wrap;">
          <label class="visibility-option <%= contest.visibility !== 'private' ? 'selected-public' : '' %>" id="opt-public">
            <input type="radio" name="visibility" value="public" <%= contest.visibility !== 'private' ? 'checked' : '' %> onchange="updateVisibility()">
            <div>
              <div style="color:#00e5a0; font-weight:600; font-size:14px;">🌐 Public</div>
              <div style="color:#7a9ab0; font-size:12px; margin-top:2px;">Anyone can view and participate</div>
            </div>
          </label>
          <label class="visibility-option <%= contest.visibility === 'private' ? 'selected-private' : '' %>" id="opt-private">
            <input type="radio" name="visibility" value="private" <%= contest.visibility === 'private' ? 'checked' : '' %> onchange="updateVisibility()">
            <div>
              <div style="color:#f5a623; font-weight:600; font-size:14px;">🔒 Private</div>
              <div style="color:#7a9ab0; font-size:12px; margin-top:2px;">Members only</div>
            </div>
          </label>
        </div>
      </div>

      <div class="form-group">
        <label>Timezone</label>
        <select name="timezone" id="timezoneSelect" onchange="updateTimePlaceholders()">
          <option value="UTC" <%= (contest.timezone === 'UTC' || !contest.timezone) ? 'selected' : '' %>>UTC (Coordinated Universal Time)</option>
          <option value="Vietnam" <%= contest.timezone === 'Vietnam' ? 'selected' : '' %>>Vietnam (UTC+7)</option>
        </select>
      </div>

      <div class="form-group">
        <label class="tag-checkbox" style="display:inline-flex;">
          <input type="checkbox" name="noTimeLimit" id="noTimeLimit"
            <%= contest.noTimeLimit ? 'checked' : '' %>
            onchange="toggleTimeLimit()">
          <span>No time limit (contest always Live)</span>
        </label>
      </div>

      <%
        let initStartDate = '', initStartHour = '', initStartMinute = '';
        let initEndDate = '', initEndHour = '', initEndMinute = '';
        if (contest.startTime) {
          const sp = contest.startTime.slice(0, 16).split('T');
          initStartDate = sp[0] || '';
          const st = (sp[1] || '').split(':');
          initStartHour = st[0] || '';
          initStartMinute = st[1] || '';
        }
        if (contest.endTime) {
          const ep = contest.endTime.slice(0, 16).split('T');
          initEndDate = ep[0] || '';
          const et = (ep[1] || '').split(':');
          initEndHour = et[0] || '';
          initEndMinute = et[1] || '';
        }
      %>

      <div id="timeLimitFields" style="<%= contest.noTimeLimit ? 'display:none' : '' %>">
        <div class="form-group">
          <label>Start Time <span id="tzLabel" style="color:#7a9ab0; font-size:12px;">(<%= contest.timezone === 'Vietnam' ? 'Vietnam UTC+7 — enter time in Vietnam time' : 'UTC — enter time in UTC' %>)</span></label>
          <div style="display:flex; gap:8px; align-items:center; flex-wrap:wrap;">
            <input type="date" id="startDate" value="<%= initStartDate %>" style="flex:1; min-width:140px;" <%= !contest.noTimeLimit ? 'required' : '' %> />
            <div style="display:flex; gap:4px; align-items:center;">
              <input type="number" id="startHour" min="0" max="23" placeholder="HH" value="<%= initStartHour %>" style="width:64px; text-align:center;" <%= !contest.noTimeLimit ? 'required' : '' %> />
              <span style="color:#7a9ab0;">:</span>
              <input type="number" id="startMinute" min="0" max="59" placeholder="MM" value="<%= initStartMinute %>" style="width:64px; text-align:center;" <%= !contest.noTimeLimit ? 'required' : '' %> />
            </div>
          </div>
          <input type="hidden" name="startTime" id="startTime" />
        </div>
        <div class="form-group">
          <label>End Time <span id="tzLabel2" style="color:#7a9ab0; font-size:12px;">(<%= contest.timezone === 'Vietnam' ? 'Vietnam UTC+7 — enter time in Vietnam time' : 'UTC — enter time in UTC' %>)</span></label>
          <div style="display:flex; gap:8px; align-items:center; flex-wrap:wrap;">
            <input type="date" id="endDate" value="<%= initEndDate %>" style="flex:1; min-width:140px;" <%= !contest.noTimeLimit ? 'required' : '' %> />
            <div style="display:flex; gap:4px; align-items:center;">
              <input type="number" id="endHour" min="0" max="23" placeholder="HH" value="<%= initEndHour %>" style="width:64px; text-align:center;" <%= !contest.noTimeLimit ? 'required' : '' %> />
              <span style="color:#7a9ab0;">:</span>
              <input type="number" id="endMinute" min="0" max="59" placeholder="MM" value="<%= initEndMinute %>" style="width:64px; text-align:center;" <%= !contest.noTimeLimit ? 'required' : '' %> />
            </div>
          </div>
          <input type="hidden" name="endTime" id="endTime" />
        </div>
        <div id="tzHint" style="background:#141e26; border:1px solid #2a3e4e; border-radius:6px; padding:10px 14px; margin-bottom:16px; color:#7a9ab0; font-size:13px;">
          💡 Current time: <strong id="currentTimeDisplay" style="color:#e0eaf0;"></strong>
        </div>
      </div>

      <div class="form-group">
        <label>Problems</label>
        <div style="margin-bottom:8px;">
          <input type="text" id="problemSearchInput" placeholder="Search your problems..." class="filter-input" oninput="searchProblems()" />
        </div>
        <div id="problemSearchResults" style="background:#141e26; border:1px solid #2a3e4e; border-radius:6px; max-height:200px; overflow-y:auto; display:none; margin-bottom:8px;"></div>
        <div id="selectedProblems" style="display:flex; flex-direction:column; gap:0;"></div>
        <div id="problemIdsContainer"></div>
      </div>

      <button type="submit" class="btn-submit" onclick="return buildDateTime()">Save Changes</button>
    </form>
  </div>

  <style>
    .drag-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: #141e26;
      border: 1px solid #2a3e4e;
      border-radius: 6px;
      padding: 10px 14px;
      margin: 3px 0;
      cursor: default;
      transition: border-color 0.15s;
    }
    .drag-item.drag-over-top {
      border-top: 3px solid #00e5a0;
    }
    .drag-item.drag-over-bottom {
      border-bottom: 3px solid #00e5a0;
    }
    .drag-handle {
      color: #7a9ab0;
      font-size: 18px;
      cursor: grab;
      padding: 0 10px 0 0;
      line-height: 1;
      flex-shrink: 0;
    }
    .drag-handle:active {
      cursor: grabbing;
    }
    .drag-item.is-dragging {
      opacity: 0.35;
      border-color: #00e5a0;
    }
  </style>

  <script>
    const selectedProblemIds = new Set();
    const SERVER_UTC = '<%= serverTime.utc %>';
    const SERVER_VN = '<%= serverTime.vietnam %>';

    // Pre-populate existing problems
    <% problems.forEach(p => { %>
      <% if (contest.problemIds.includes(p.id)) { %>
        addProblem('<%= p.id %>', '<%= p.title.replace(/'/g, "\\'") %>', '<%= p.difficulty %>', true);
      <% } %>
    <% }) %>

    function pad(n) { return String(n).padStart(2, '0'); }

    function buildDateTime() {
      const noLimit = document.getElementById('noTimeLimit').checked;
      if (noLimit) return true;
      const sd = document.getElementById('startDate').value;
      const sh = document.getElementById('startHour').value;
      const sm = document.getElementById('startMinute').value;
      const ed = document.getElementById('endDate').value;
      const eh = document.getElementById('endHour').value;
      const em = document.getElementById('endMinute').value;
      if (!sd || sh === '' || sm === '' || !ed || eh === '' || em === '') {
        alert('Please fill in all date and time fields.');
        return false;
      }
      document.getElementById('startTime').value = sd + 'T' + pad(sh) + ':' + pad(sm);
      document.getElementById('endTime').value = ed + 'T' + pad(eh) + ':' + pad(em);
      return true;
    }

    function updateVisibility() {
      const isPublic = document.querySelector('input[name="visibility"][value="public"]').checked;
      document.getElementById('opt-public').className = isPublic ? 'visibility-option selected-public' : 'visibility-option';
      document.getElementById('opt-private').className = !isPublic ? 'visibility-option selected-private' : 'visibility-option';
    }

    function toggleTimeLimit() {
      const checked = document.getElementById('noTimeLimit').checked;
      document.getElementById('timeLimitFields').style.display = checked ? 'none' : 'block';
      const timeInputs = ['startDate', 'startHour', 'startMinute', 'endDate', 'endHour', 'endMinute'];
      timeInputs.forEach(id => {
        const el = document.getElementById(id);
        if (el) {
          if (checked) el.removeAttribute('required');
          else el.setAttribute('required', '');
        }
      });
    }

    function updateTimePlaceholders() {
      const tz = document.getElementById('timezoneSelect').value;
      const isVietnam = tz === 'Vietnam';
      const label = isVietnam ? '(Vietnam UTC+7 — enter time in Vietnam time)' : '(UTC — enter time in UTC)';
      document.getElementById('tzLabel').textContent = label;
      document.getElementById('tzLabel2').textContent = label;
      updateCurrentTime();
    }

    function updateCurrentTime() {
      const tz = document.getElementById('timezoneSelect').value;
      document.getElementById('currentTimeDisplay').textContent = tz === 'Vietnam' ? SERVER_VN : SERVER_UTC;
    }

    updateCurrentTime();

    async function searchProblems() {
      const q = document.getElementById('problemSearchInput').value.trim();
      const resultsDiv = document.getElementById('problemSearchResults');
      if (q.length === 0) { resultsDiv.style.display = 'none'; return; }
      const res = await fetch('/api/my-problems?q=' + encodeURIComponent(q));
      const problems = await res.json();
      if (problems.length === 0) {
        resultsDiv.innerHTML = '<div style="padding:12px 16px; color:#7a9ab0; font-size:13px;">No problems found.</div>';
      } else {
        resultsDiv.innerHTML = problems
          .filter(p => !selectedProblemIds.has(p.id))
          .map(p => `
            <div style="padding:10px 16px; display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid #2a3e4e; cursor:pointer;"
              onmouseenter="this.style.background='#1a2a36'"
              onmouseleave="this.style.background=''"
              onclick="addProblem('${p.id}', '${p.title.replace(/'/g, "\\'")}', '${p.difficulty}')">
              <span style="color:#e0eaf0; font-size:14px;">${p.title}</span>
              <span class="difficulty-${p.difficulty.toLowerCase()}" style="font-size:12px;">${p.difficulty}</span>
            </div>
          `).join('');
      }
      resultsDiv.style.display = 'block';
    }

    function addProblem(id, title, difficulty, silent = false) {
      if (selectedProblemIds.has(id)) return;
      selectedProblemIds.add(id);

      const container = document.getElementById('selectedProblems');
      const div = document.createElement('div');
      div.id = 'selected-' + id;
      div.className = 'drag-item';
      div.draggable = true;
      div.dataset.id = id;
      div.innerHTML = `
        <div style="display:flex; align-items:center; flex:1; min-width:0;">
          <span class="drag-handle" title="Drag to reorder">⠿</span>
          <span style="color:#e0eaf0; font-size:14px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
            ${title} <span class="difficulty-${difficulty.toLowerCase()}" style="font-size:12px;">(${difficulty})</span>
          </span>
        </div>
        <button type="button" onclick="removeProblem('${id}')" style="flex-shrink:0; margin-left:10px; background:transparent; border:1px solid #ff4444; color:#ff4444; padding:4px 10px; border-radius:4px; cursor:pointer; font-size:12px;">Remove</button>
      `;

      bindDragEvents(div);
      container.appendChild(div);
      syncHiddenInputOrder();

      if (!silent) {
        document.getElementById('problemSearchInput').value = '';
        document.getElementById('problemSearchResults').style.display = 'none';
      }
    }

    function removeProblem(id) {
      selectedProblemIds.delete(id);
      const el = document.getElementById('selected-' + id);
      if (el) el.remove();
      syncHiddenInputOrder();
    }

    // ── Drag & Drop ──────────────────────────────────────────

    let dragSrcEl = null;

    function bindDragEvents(el) {
      el.addEventListener('dragstart', function(e) {
        dragSrcEl = this;
        e.dataTransfer.effectAllowed = 'move';
        e.dataTransfer.setData('text/plain', this.dataset.id);
        setTimeout(() => this.classList.add('is-dragging'), 0);
      });

      el.addEventListener('dragend', function(e) {
        this.classList.remove('is-dragging');
        clearAllIndicators();
        dragSrcEl = null;
        syncHiddenInputOrder();
      });

      el.addEventListener('dragover', function(e) {
        e.preventDefault();
        if (!dragSrcEl || dragSrcEl === this) return;
        e.dataTransfer.dropEffect = 'move';
        clearAllIndicators();
        const rect = this.getBoundingClientRect();
        const mid = rect.top + rect.height / 2;
        if (e.clientY < mid) {
          this.classList.add('drag-over-top');
        } else {
          this.classList.add('drag-over-bottom');
        }
      });

      el.addEventListener('dragleave', function(e) {
        this.classList.remove('drag-over-top');
        this.classList.remove('drag-over-bottom');
      });

      el.addEventListener('drop', function(e) {
        e.preventDefault();
        if (!dragSrcEl || dragSrcEl === this) return;
        const container = document.getElementById('selectedProblems');
        const rect = this.getBoundingClientRect();
        const mid = rect.top + rect.height / 2;
        clearAllIndicators();
        if (e.clientY < mid) {
          container.insertBefore(dragSrcEl, this);
        } else {
          const next = this.nextElementSibling;
          if (next) {
            container.insertBefore(dragSrcEl, next);
          } else {
            container.appendChild(dragSrcEl);
          }
        }
        syncHiddenInputOrder();
      });
    }

    function clearAllIndicators() {
      document.querySelectorAll('.drag-item').forEach(el => {
        el.classList.remove('drag-over-top');
        el.classList.remove('drag-over-bottom');
      });
    }

    function syncHiddenInputOrder() {
      const container = document.getElementById('selectedProblems');
      const hiddenContainer = document.getElementById('problemIdsContainer');
      hiddenContainer.innerHTML = '';
      container.querySelectorAll('.drag-item').forEach(item => {
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'problemIds[]';
        input.value = item.dataset.id;
        hiddenContainer.appendChild(input);
      });
    }

    fetch('/notifications/count').then(r => r.json()).then(data => {
      if (data.count > 0) {
        const badge = document.getElementById('notifBadge');
        badge.textContent = data.count;
        badge.style.display = 'inline-block';
      }
    });
  </script>
</body>
</html>