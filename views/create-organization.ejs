<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create Organization - DOJ</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
</head>
<body>
  <nav class="navbar">
    <div class="nav-left">
      <a href="/" class="logo">DOJ</a>
      <a href="/problems" class="nav-link">Problems</a>
      <a href="/organizations" class="nav-link">Organizations</a>
    </div>
    <div class="nav-right">
      <span class="nav-username"><%= user.username %></span>
      <a href="/logout" class="btn-logout">Logout</a>
    </div>
  </nav>

  <div class="create-container">
    <h2>Create Organization</h2>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="error-msg"><%= error %></div>
    <% } %>
    <form action="/organizations/create" method="POST">
      <div class="form-group">
        <label>Organization Name</label>
        <input type="text" name="name" placeholder="Enter organization name" required />
      </div>
      <div class="form-group">
        <label>Description</label>
        <textarea name="description" rows="4" placeholder="Describe your organization..."></textarea>
      </div>
      <div class="form-group">
        <label>Visibility</label>
        <div style="display:flex; gap:12px; margin-top:8px; flex-wrap:wrap;">
          <label class="visibility-option selected-public" id="opt-public">
            <input type="radio" name="hidden" value="false" checked onchange="updateVisibility()">
            <div>
              <div style="color:#00e5a0; font-weight:600; font-size:14px;">🌐 Public</div>
              <div style="color:#7a9ab0; font-size:12px; margin-top:2px;">Contests are visible to everyone</div>
            </div>
          </label>
          <label class="visibility-option" id="opt-hidden">
            <input type="radio" name="hidden" value="true" onchange="updateVisibility()">
            <div>
              <div style="color:#f5a623; font-weight:600; font-size:14px;">🔒 Hidden</div>
              <div style="color:#7a9ab0; font-size:12px; margin-top:2px;">Members only can view content</div>
            </div>
          </label>
        </div>
      </div>
      <button type="submit" class="btn-submit">Create Organization</button>
    </form>
  </div>

  <script>
    function updateVisibility() {
      const isPublic = document.querySelector('input[name="hidden"][value="false"]').checked;
      document.getElementById('opt-public').className = isPublic ? 'visibility-option selected-public' : 'visibility-option';
      document.getElementById('opt-hidden').className = !isPublic ? 'visibility-option selected-private' : 'visibility-option';
    }
  </script>
</body>
</html>