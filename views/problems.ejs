<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Problems - DOJ</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
</head>
<body>
  <nav class="navbar">
    <div class="nav-left">
      <a href="/" class="logo">DOJ</a>
      <a href="/problems" class="nav-link active">Problems</a>
      <a href="/organizations" class="nav-link">Organizations</a>
      <a href="/leaderboard" class="nav-link">Leaderboard</a>
      <% if (user && user.role === 'admin') { %>
        <a href="/admin" class="nav-link">Admin</a>
      <% } %>
    </div>
    <div class="nav-right">
      <% if (user) { %>
        <a href="/notifications" class="notif-btn">
          🔔 <span class="notif-badge" id="notifBadge" style="display:none;">0</span>
        </a>
        <a href="/profile/<%= user.username %>" class="nav-username"><%= user.username %></a>
        <a href="/logout" class="btn-logout">Logout</a>
      <% } else { %>
        <a href="/login" class="btn-login">Log In</a>
        <a href="/register" class="btn-register">Sign Up</a>
      <% } %>
    </div>
  </nav>

  <div class="problems-container">
    <div class="problems-header">
      <h2>Problems</h2>
    </div>

    <div class="filter-bar">
      <input type="text" id="searchInput" placeholder="Search problems..." class="filter-input" />
      <select id="difficultyFilter" class="filter-select">
        <option value="">All Difficulties</option>
        <option value="Easy">Easy</option>
        <option value="Medium">Medium</option>
        <option value="Hard">Hard</option>
      </select>
      <select id="tagFilter" class="filter-select">
        <option value="">All Tags</option>
        <% ['Arrays', 'Strings', 'Math', 'Sorting', 'Searching', 'Dynamic Programming', 'Greedy', 'Graph', 'Tree', 'Recursion', 'Stack', 'Queue', 'Linked List', 'Binary Search', 'Two Pointers', 'Bit Manipulation', 'Geometry', 'Number Theory'].forEach(tag => { %>
          <option value="<%= tag %>"><%= tag %></option>
        <% }) %>
      </select>
    </div>

    <% if (problems.length === 0) { %>
      <div style="text-align:center; color:#a0a0b0; padding:60px 0;">
        <p>No featured problems yet.</p>
        <% if (user && user.role === 'admin') { %>
          <p style="font-size:13px;">Go to <a href="/admin" style="color:#00e5a0;">Admin Panel</a> to feature problems.</p>
        <% } %>
      </div>
    <% } else { %>
      <table class="problems-table" id="problemsTable">
        <thead>
          <tr>
            <th>#</th>
            <th>Title</th>
            <th>Organization</th>
            <th>Tags</th>
            <th>Difficulty</th>
            <th>Acceptance</th>
            <% if (user) { %><th>Status</th><% } %>
          </tr>
        </thead>
        <tbody id="problemsBody">
          <% problems.forEach((problem, index) => { %>
            <tr class="problem-row"
                data-title="<%= problem.title.toLowerCase() %>"
                data-difficulty="<%= problem.difficulty %>"
                data-tags="<%= (problem.tags || []).join(',').toLowerCase() %>">
              <td><%= index + 1 %></td>
              <td><a href="/problems/<%= problem.id %>"><%= problem.title %></a></td>
              <td style="color:#a0a0b0; font-size:13px;">
                <% if (problem.orgName) { %>
                  <a href="/organizations/<%= problem.orgId %>" style="color:#a0a0c0; text-decoration:none; font-size:13px;"><%= problem.orgName %></a>
                <% } else { %>
                  —
                <% } %>
              </td>
              <td>
                <% if (problem.tags && problem.tags.length > 0) { %>
                  <% problem.tags.slice(0, 2).forEach(tag => { %>
                    <span class="tag-badge tag-badge-sm"><%= tag %></span>
                  <% }) %>
                  <% if (problem.tags.length > 2) { %>
                    <span style="color:#a0a0b0; font-size:12px;">+<%= problem.tags.length - 2 %></span>
                  <% } %>
                <% } else { %>
                  <span style="color:#a0a0b0; font-size:12px;">—</span>
                <% } %>
              </td>
              <td class="difficulty-<%= problem.difficulty.toLowerCase() %>"><%= problem.difficulty %></td>
              <td style="color:#a0a0b0; font-size:13px;">
                <% if (problem.totalSubmissions > 0) { %>
                  <span style="color:#00e5a0;"><%= Math.round(problem.acceptedSubmissions / problem.totalSubmissions * 100) %>%</span>
                <% } else { %>
                  —
                <% } %>
              </td>
              <% if (user) { %>
                <td>
                  <% if (problem.solved) { %>
                    <span style="color:#00e5a0; font-weight:600;">✓ Solved</span>
                  <% } else { %>
                    <span style="color:#a0a0b0;">—</span>
                  <% } %>
                </td>
              <% } %>
            </tr>
          <% }) %>
        </tbody>
      </table>

      <div id="noResults" style="display:none; text-align:center; color:#a0a0b0; padding:40px;">
        No problems match your search.
      </div>
    <% } %>
  </div>

  <script>
    const searchInput = document.getElementById('searchInput');
    const difficultyFilter = document.getElementById('difficultyFilter');
    const tagFilter = document.getElementById('tagFilter');
    const rows = document.querySelectorAll('.problem-row');
    const noResults = document.getElementById('noResults');
    const table = document.getElementById('problemsTable');

    function filterProblems() {
      const search = searchInput ? searchInput.value.toLowerCase() : '';
      const difficulty = difficultyFilter ? difficultyFilter.value : '';
      const tag = tagFilter ? tagFilter.value.toLowerCase() : '';
      let visible = 0;
      rows.forEach(row => {
        const matchSearch = row.dataset.title.includes(search);
        const matchDiff = difficulty === '' || row.dataset.difficulty === difficulty;
        const matchTag = tag === '' || row.dataset.tags.includes(tag);
        if (matchSearch && matchDiff && matchTag) { row.style.display = ''; visible++; }
        else row.style.display = 'none';
      });
      if (noResults) noResults.style.display = visible === 0 && rows.length > 0 ? 'block' : 'none';
      if (table) table.style.display = visible === 0 ? 'none' : '';
    }

    if (searchInput) searchInput.addEventListener('input', filterProblems);
    if (difficultyFilter) difficultyFilter.addEventListener('change', filterProblems);
    if (tagFilter) tagFilter.addEventListener('change', filterProblems);

    <% if (user) { %>
    fetch('/notifications/count').then(r => r.json()).then(data => {
      if (data.count > 0) {
        const badge = document.getElementById('notifBadge');
        badge.textContent = data.count;
        badge.style.display = 'inline-block';
      }
    });
    <% } %>
  </script>
</body>
</html>