<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Problem - DOJ</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
</head>
<body>
  <nav class="navbar">
    <div class="nav-left">
      <a href="/" class="logo">DOJ</a>
      <a href="/problems" class="nav-link">Problems</a>
      <a href="/organizations" class="nav-link">Organizations</a>
      <a href="/leaderboard" class="nav-link">Leaderboard</a>
    </div>
    <div class="nav-right">
      <a href="/profile/<%= user.username %>" class="nav-username"><%= user.username %></a>
      <a href="/logout" class="btn-logout">Logout</a>
    </div>
  </nav>

  <div class="create-container">
    <h2>Edit Problem</h2>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="error-msg"><%= error %></div>
    <% } %>
    <form action="/problems/<%= problem.id %>/edit" method="POST">
      <div class="form-group">
        <label>Title</label>
        <input type="text" name="title" value="<%= problem.title %>" required />
      </div>
      <div class="form-group">
        <label>Difficulty</label>
        <select name="difficulty">
          <option value="Easy" <%= problem.difficulty === 'Easy' ? 'selected' : '' %>>Easy</option>
          <option value="Medium" <%= problem.difficulty === 'Medium' ? 'selected' : '' %>>Medium</option>
          <option value="Hard" <%= problem.difficulty === 'Hard' ? 'selected' : '' %>>Hard</option>
        </select>
      </div>
      <div class="form-group">
        <label>Tags</label>
        <div class="tags-grid">
          <% ['Arrays', 'Strings', 'Math', 'Sorting', 'Searching', 'Dynamic Programming', 'Greedy', 'Graph', 'Tree', 'Recursion', 'Stack', 'Queue', 'Linked List', 'Binary Search', 'Two Pointers', 'Bit Manipulation', 'Geometry', 'Number Theory'].forEach(tag => { %>
            <label class="tag-checkbox">
              <input type="checkbox" name="tags[]" value="<%= tag %>"
                <%= (problem.tags && problem.tags.includes(tag)) ? 'checked' : '' %>>
              <span><%= tag %></span>
            </label>
          <% }) %>
        </div>
      </div>
      <div class="form-group">
        <label>Time Limit (seconds)</label>
        <select name="timeLimit">
          <% [1,2,3,4,5].forEach(t => { %>
            <option value="<%= t %>" <%= problem.timeLimit === t ? 'selected' : '' %>><%= t %> second<%= t > 1 ? 's' : '' %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label>Problem Statement</label>
        <textarea name="statement" rows="8" required><%= problem.statement %></textarea>
      </div>
      <div class="form-group">
        <label>Input Format</label>
        <textarea name="inputFormat" rows="4"><%= problem.inputFormat %></textarea>
      </div>
      <div class="form-group">
        <label>Output Format</label>
        <textarea name="outputFormat" rows="4"><%= problem.outputFormat %></textarea>
      </div>
      <div class="form-group">
        <label>Constraints</label>
        <textarea name="constraints" rows="4"><%= problem.constraints || '' %></textarea>
      </div>
      <div class="form-group">
        <label>Explanation (optional)</label>
        <textarea name="explanation" rows="4"><%= problem.explanation || '' %></textarea>
      </div>

      <div class="form-group">
        <label>Sample Test Cases</label>
        <div id="sampleTestcases">
          <% (problem.sampleTestcases || []).forEach((tc, i) => { %>
            <div class="testcase-row" id="sample-<%= i %>">
              <div style="display:flex; gap:12px; margin-bottom:8px;">
                <div style="flex:1;">
                  <label style="font-size:12px; color:#7a9ab0;">Input</label>
                  <textarea name="sampleInput[]" rows="3" class="testcase-input"><%= tc.input %></textarea>
                </div>
                <div style="flex:1;">
                  <label style="font-size:12px; color:#7a9ab0;">Output</label>
                  <textarea name="sampleOutput[]" rows="3" class="testcase-input"><%= tc.output %></textarea>
                </div>
                <button type="button" onclick="removeTestcase('sample-<%= i %>')" class="btn-remove-tc">✕</button>
              </div>
            </div>
          <% }) %>
        </div>
        <button type="button" onclick="addSampleTestcase()" class="btn-add-tc">+ Add Sample</button>
      </div>

      <div class="form-group">
        <label>Hidden Test Cases</label>
        <div id="hiddenTestcases">
          <% (problem.hiddenTestcases || []).forEach((tc, i) => { %>
            <div class="testcase-row" id="hidden-<%= i %>">
              <div style="display:flex; gap:12px; margin-bottom:8px;">
                <div style="flex:1;">
                  <label style="font-size:12px; color:#7a9ab0;">Input</label>
                  <textarea name="hiddenInput[]" rows="3" class="testcase-input"><%= tc.input %></textarea>
                </div>
                <div style="flex:1;">
                  <label style="font-size:12px; color:#7a9ab0;">Output</label>
                  <textarea name="hiddenOutput[]" rows="3" class="testcase-input"><%= tc.output %></textarea>
                </div>
                <button type="button" onclick="removeTestcase('hidden-<%= i %>')" class="btn-remove-tc">✕</button>
              </div>
            </div>
          <% }) %>
        </div>
        <button type="button" onclick="addHiddenTestcase()" class="btn-add-tc">+ Add Hidden</button>
      </div>

      <button type="submit" class="btn-submit-form">Save Changes</button>
    </form>
  </div>

  <script>
    let sampleCount = <%= (problem.sampleTestcases || []).length %>;
    let hiddenCount = <%= (problem.hiddenTestcases || []).length %>;

    function addSampleTestcase() {
      const container = document.getElementById('sampleTestcases');
      const div = document.createElement('div');
      div.className = 'testcase-row';
      div.id = 'sample-' + sampleCount;
      div.innerHTML = `
        <div style="display:flex; gap:12px; margin-bottom:8px;">
          <div style="flex:1;">
            <label style="font-size:12px; color:#7a9ab0;">Input</label>
            <textarea name="sampleInput[]" rows="3" class="testcase-input"></textarea>
          </div>
          <div style="flex:1;">
            <label style="font-size:12px; color:#7a9ab0;">Output</label>
            <textarea name="sampleOutput[]" rows="3" class="testcase-input"></textarea>
          </div>
          <button type="button" onclick="removeTestcase('sample-${sampleCount}')" class="btn-remove-tc">✕</button>
        </div>`;
      container.appendChild(div);
      sampleCount++;
    }

    function addHiddenTestcase() {
      const container = document.getElementById('hiddenTestcases');
      const div = document.createElement('div');
      div.className = 'testcase-row';
      div.id = 'hidden-' + hiddenCount;
      div.innerHTML = `
        <div style="display:flex; gap:12px; margin-bottom:8px;">
          <div style="flex:1;">
            <label style="font-size:12px; color:#7a9ab0;">Input</label>
            <textarea name="hiddenInput[]" rows="3" class="testcase-input"></textarea>
          </div>
          <div style="flex:1;">
            <label style="font-size:12px; color:#7a9ab0;">Output</label>
            <textarea name="hiddenOutput[]" rows="3" class="testcase-input"></textarea>
          </div>
          <button type="button" onclick="removeTestcase('hidden-${hiddenCount}')" class="btn-remove-tc">✕</button>
        </div>`;
      container.appendChild(div);
      hiddenCount++;
    }

    function removeTestcase(id) {
      const el = document.getElementById(id);
      if (el) el.remove();
    }
  </script>
</body>
</html>