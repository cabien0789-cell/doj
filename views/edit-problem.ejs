<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Problem - DOJ</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
</head>
<body>
  <nav class="navbar">
    <div class="nav-left">
      <a href="/" class="logo">DOJ</a>
      <a href="/problems" class="nav-link">Problems</a>
      <a href="/organizations" class="nav-link">Organizations</a>
      <a href="/leaderboard" class="nav-link">Leaderboard</a>
    </div>
    <div class="nav-right">
      <a href="/problems/create" class="btn-register">+ Create</a>
      <a href="/profile/<%= user.username %>" class="nav-username"><%= user.username %></a>
      <a href="/logout" class="btn-logout">Logout</a>
    </div>
  </nav>

  <div class="create-container">
    <h2>Edit Problem</h2>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="error-msg"><%= error %></div>
    <% } %>
    <form action="/problems/<%= problem.id %>/edit" method="POST">
      <div class="form-group">
        <label>Title</label>
        <input type="text" name="title" value="<%= problem.title %>" required />
      </div>
      <div class="form-group">
        <label>Difficulty</label>
        <select name="difficulty">
          <option value="Easy" <%= problem.difficulty === 'Easy' ? 'selected' : '' %>>Easy</option>
          <option value="Medium" <%= problem.difficulty === 'Medium' ? 'selected' : '' %>>Medium</option>
          <option value="Hard" <%= problem.difficulty === 'Hard' ? 'selected' : '' %>>Hard</option>
        </select>
      </div>
      <div class="form-group">
        <label>Tags <span style="color:#a0a0b0; font-size:12px;">(chọn một hoặc nhiều)</span></label>
        <div class="tags-grid">
          <% ['Arrays', 'Strings', 'Math', 'Sorting', 'Searching', 'Dynamic Programming', 'Greedy', 'Graph', 'Tree', 'Recursion', 'Stack', 'Queue', 'Linked List', 'Binary Search', 'Two Pointers', 'Bit Manipulation', 'Geometry', 'Number Theory'].forEach(tag => { %>
            <label class="tag-checkbox">
              <input type="checkbox" name="tags[]" value="<%= tag %>"
                <%= (problem.tags && problem.tags.includes(tag)) ? 'checked' : '' %>>
              <span><%= tag %></span>
            </label>
          <% }) %>
        </div>
      </div>
      <div class="form-group">
        <label>Time Limit (seconds)</label>
        <select name="timeLimit">
          <option value="1" <%= problem.timeLimit == 1 ? 'selected' : '' %>>1 second</option>
          <option value="2" <%= (!problem.timeLimit || problem.timeLimit == 2) ? 'selected' : '' %>>2 seconds</option>
          <option value="3" <%= problem.timeLimit == 3 ? 'selected' : '' %>>3 seconds</option>
          <option value="5" <%= problem.timeLimit == 5 ? 'selected' : '' %>>5 seconds</option>
          <option value="10" <%= problem.timeLimit == 10 ? 'selected' : '' %>>10 seconds</option>
        </select>
      </div>
      <div class="form-group">
        <label>Problem Statement</label>
        <textarea name="statement" rows="8" required><%= problem.statement %></textarea>
      </div>
      <div class="form-group">
        <label>Input Format</label>
        <textarea name="inputFormat" rows="3" required><%= problem.inputFormat %></textarea>
      </div>
      <div class="form-group">
        <label>Output Format</label>
        <textarea name="outputFormat" rows="3" required><%= problem.outputFormat %></textarea>
      </div>
      <div class="form-group">
        <label>Constraints <span style="color:#a0a0b0; font-size:12px;">(không bắt buộc)</span></label>
        <textarea name="constraints" rows="3"><%= problem.constraints || '' %></textarea>
      </div>
      <div class="form-group">
        <label>Explanation <span style="color:#a0a0b0; font-size:12px;">(không bắt buộc)</span></label>
        <textarea name="explanation" rows="4"><%= problem.explanation || '' %></textarea>
      </div>

      <!-- Sample Test Cases -->
      <div class="testcases-section">
        <h3>Sample Test Cases <span style="color:#a0a0b0; font-size:13px; font-weight:400;">(hiển thị công khai)</span></h3>
        <div id="sampleTestcases">
          <% (problem.sampleTestcases || problem.testcases || []).forEach((tc, i) => { %>
            <div class="testcase">
              <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
                <span style="color:#a0a0b0; font-size:13px;">Sample #<%= i+1 %></span>
                <button type="button" class="btn-remove-tc" onclick="removeTestcase(this, 'sample')">Remove</button>
              </div>
              <div class="form-group">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
                  <label style="margin:0;">Input</label>
                  <label class="upload-btn"><input type="file" accept=".txt" onchange="loadFile(this, 'input')"> 📁 Upload .txt</label>
                </div>
                <textarea name="sampleInput[]" rows="3"><%= tc.input %></textarea>
              </div>
              <div class="form-group">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
                  <label style="margin:0;">Output</label>
                  <label class="upload-btn"><input type="file" accept=".txt" onchange="loadFile(this, 'output')"> 📁 Upload .txt</label>
                </div>
                <textarea name="sampleOutput[]" rows="3"><%= tc.output %></textarea>
              </div>
            </div>
          <% }) %>
        </div>
        <button type="button" class="btn-add-tc" onclick="addTestcase('sample')">+ Add Sample Test Case</button>
      </div>

      <!-- Hidden Test Cases -->
      <div class="testcases-section">
        <h3>Hidden Test Cases <span style="color:#a0a0b0; font-size:13px; font-weight:400;">(chỉ dùng để chấm)</span></h3>
        <div id="hiddenTestcases">
          <% (problem.hiddenTestcases || []).forEach((tc, i) => { %>
            <div class="testcase">
              <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
                <span style="color:#a0a0b0; font-size:13px;">Hidden #<%= i+1 %></span>
                <button type="button" class="btn-remove-tc" onclick="removeTestcase(this, 'hidden')">Remove</button>
              </div>
              <div class="form-group">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
                  <label style="margin:0;">Input</label>
                  <label class="upload-btn"><input type="file" accept=".txt" onchange="loadFile(this, 'input')"> 📁 Upload .txt</label>
                </div>
                <textarea name="hiddenInput[]" rows="3"><%= tc.input %></textarea>
              </div>
              <div class="form-group">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
                  <label style="margin:0;">Output</label>
                  <label class="upload-btn"><input type="file" accept=".txt" onchange="loadFile(this, 'output')"> 📁 Upload .txt</label>
                </div>
                <textarea name="hiddenOutput[]" rows="3"><%= tc.output %></textarea>
              </div>
            </div>
          <% }) %>
          <% if (!problem.hiddenTestcases || problem.hiddenTestcases.length === 0) { %>
            <div class="testcase">
              <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
                <span style="color:#a0a0b0; font-size:13px;">Hidden #1</span>
                <button type="button" class="btn-remove-tc" onclick="removeTestcase(this, 'hidden')">Remove</button>
              </div>
              <div class="form-group">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
                  <label style="margin:0;">Input</label>
                  <label class="upload-btn"><input type="file" accept=".txt" onchange="loadFile(this, 'input')"> 📁 Upload .txt</label>
                </div>
                <textarea name="hiddenInput[]" rows="3"></textarea>
              </div>
              <div class="form-group">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
                  <label style="margin:0;">Output</label>
                  <label class="upload-btn"><input type="file" accept=".txt" onchange="loadFile(this, 'output')"> 📁 Upload .txt</label>
                </div>
                <textarea name="hiddenOutput[]" rows="3"></textarea>
              </div>
            </div>
          <% } %>
        </div>
        <button type="button" class="btn-add-tc" onclick="addTestcase('hidden')">+ Add Hidden Test Case</button>
      </div>

      <button type="submit" class="btn-submit">Save Changes</button>
    </form>
  </div>

  <script>
    function addTestcase(type) {
      const container = document.getElementById(type + 'Testcases');
      const count = container.children.length + 1;
      const label = type === 'sample' ? 'Sample' : 'Hidden';
      const inputName = type === 'sample' ? 'sampleInput[]' : 'hiddenInput[]';
      const outputName = type === 'sample' ? 'sampleOutput[]' : 'hiddenOutput[]';

      const div = document.createElement('div');
      div.className = 'testcase';
      div.innerHTML = `
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
          <span style="color:#a0a0b0; font-size:13px;">${label} #${count}</span>
          <button type="button" class="btn-remove-tc" onclick="removeTestcase(this, '${type}')">Remove</button>
        </div>
        <div class="form-group">
          <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
            <label style="margin:0;">Input</label>
            <label class="upload-btn"><input type="file" accept=".txt" onchange="loadFile(this, 'input')"> 📁 Upload .txt</label>
          </div>
          <textarea name="${inputName}" rows="3" placeholder="${label} input..."></textarea>
        </div>
        <div class="form-group">
          <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
            <label style="margin:0;">Output</label>
            <label class="upload-btn"><input type="file" accept=".txt" onchange="loadFile(this, 'output')"> 📁 Upload .txt</label>
          </div>
          <textarea name="${outputName}" rows="3" placeholder="${label} output..."></textarea>
        </div>
      `;
      container.appendChild(div);
      renumberTestcases(type);
    }

    function removeTestcase(btn, type) {
      const container = document.getElementById(type + 'Testcases');
      if (container.children.length <= 1) return;
      btn.closest('.testcase').remove();
      renumberTestcases(type);
    }

    function renumberTestcases(type) {
      const container = document.getElementById(type + 'Testcases');
      const label = type === 'sample' ? 'Sample' : 'Hidden';
      Array.from(container.children).forEach((div, i) => {
        const span = div.querySelector('span');
        if (span) span.textContent = `${label} #${i + 1}`;
      });
    }

    function loadFile(input, field) {
      const file = input.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = function(e) {
        const tc = input.closest('.testcase');
        const textareas = tc.querySelectorAll('textarea');
        if (field === 'input') textareas[0].value = e.target.result;
        else textareas[1].value = e.target.result;
      };
      reader.readAsText(file);
    }
  </script>
</body>
</html>