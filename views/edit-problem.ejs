<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Problem - DOJ</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
</head>
<body>
  <nav class="navbar">
    <div class="nav-left">
      <a href="/" class="logo">DOJ</a>
      <a href="/problems" class="nav-link">Problems</a>
      <a href="/organizations" class="nav-link">Organizations</a>
      <a href="/leaderboard" class="nav-link">Leaderboard</a>
    </div>
    <div class="nav-right">
      <a href="/problems/create" class="btn-register">+ Create</a>
      <a href="/profile/<%= user.username %>" class="nav-username"><%= user.username %></a>
      <a href="/logout" class="btn-logout">Logout</a>
    </div>
  </nav>

  <div class="create-container">
    <h2>Edit Problem</h2>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="error-msg"><%= error %></div>
    <% } %>
    <form action="/problems/<%= problem.id %>/edit" method="POST" enctype="multipart/form-data">
      <div class="form-group">
        <label>Title</label>
        <input type="text" name="title" value="<%= problem.title %>" required />
      </div>
      <div class="form-group">
        <label>Difficulty</label>
        <select name="difficulty">
          <option value="Easy" <%= problem.difficulty === 'Easy' ? 'selected' : '' %>>Easy</option>
          <option value="Medium" <%= problem.difficulty === 'Medium' ? 'selected' : '' %>>Medium</option>
          <option value="Hard" <%= problem.difficulty === 'Hard' ? 'selected' : '' %>>Hard</option>
        </select>
      </div>
      <div class="form-group">
        <label>Tags</label>
        <div class="tags-grid">
          <% ['Arrays', 'Strings', 'Math', 'Sorting', 'Searching', 'Dynamic Programming', 'Greedy', 'Graph', 'Tree', 'Recursion', 'Stack', 'Queue', 'Linked List', 'Binary Search', 'Two Pointers', 'Bit Manipulation', 'Geometry', 'Number Theory'].forEach(tag => { %>
            <label class="tag-checkbox">
              <input type="checkbox" name="tags[]" value="<%= tag %>"
                <%= (problem.tags && problem.tags.includes(tag)) ? 'checked' : '' %>>
              <span><%= tag %></span>
            </label>
          <% }) %>
        </div>
      </div>
      <div class="form-group">
        <label>Time Limit (seconds)</label>
        <select name="timeLimit">
          <option value="1" <%= problem.timeLimit == 1 ? 'selected' : '' %>>1 second</option>
          <option value="2" <%= (!problem.timeLimit || problem.timeLimit == 2) ? 'selected' : '' %>>2 seconds</option>
          <option value="3" <%= problem.timeLimit == 3 ? 'selected' : '' %>>3 seconds</option>
          <option value="5" <%= problem.timeLimit == 5 ? 'selected' : '' %>>5 seconds</option>
          <option value="10" <%= problem.timeLimit == 10 ? 'selected' : '' %>>10 seconds</option>
        </select>
      </div>
      <div class="form-group">
        <label>Problem Statement</label>
        <textarea name="statement" rows="8" required><%= problem.statement %></textarea>
      </div>
      <div class="form-group">
        <label>Input Format</label>
        <textarea name="inputFormat" rows="3" required><%= problem.inputFormat %></textarea>
      </div>
      <div class="form-group">
        <label>Output Format</label>
        <textarea name="outputFormat" rows="3" required><%= problem.outputFormat %></textarea>
      </div>
      <div class="form-group">
        <label>Constraints</label>
        <textarea name="constraints" rows="3"><%= problem.constraints || '' %></textarea>
      </div>
      <div class="form-group">
        <label>Explanation</label>
        <textarea name="explanation" rows="4"><%= problem.explanation || '' %></textarea>
      </div>

      <div class="testcases-section">
        <h3>Sample Test Cases</h3>
        <div id="sampleTestcases">
          <% (problem.sampleTestcases || problem.testcases || []).forEach((tc, i) => { %>
            <div class="testcase">
              <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
                <span style="color:#a0a0b0; font-size:13px;">Sample #<%= i+1 %></span>
                <button type="button" class="btn-remove-tc" onclick="removeTestcase(this, 'sample')">Remove</button>
              </div>
              <input type="hidden" name="keep_sample_<%= i %>" value="1" id="keepSample-<%= i %>">
              <div style="background:#1a1a2e; border:1px solid #2a2a4a; border-radius:4px; padding:10px 14px; margin-bottom:8px; font-size:13px; color:#a0a0b0;">
                ✓ Testcase đã có dữ liệu (<%= tc.input.split('\n').length %> dòng input, <%= tc.output.split('\n').length %> dòng output)
                <span style="color:#00e5a0; margin-left:8px; font-size:12px;">— Giữ nguyên nếu không thay thế</span>
              </div>
              <div class="form-group">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
                  <label style="margin:0; color:#a0a0b0; font-size:12px;">Thay thế Input (tuỳ chọn)</label>
                  <label class="upload-btn"><input type="file" accept=".txt" onchange="handleFileUpload(this, 'sampleInput', <%= i %>)"> 📁 Upload .txt</label>
                </div>
                <div class="tc-file-info" id="sampleInputFileInfo-<%= i %>" style="display:none; background:#1a1a2e; border:1px solid #00e5a0; border-radius:4px; padding:8px 12px; margin-bottom:6px; font-size:13px; color:#00e5a0;"></div>
                <textarea rows="2" placeholder="Hoặc nhập thủ công để thay thế..." id="sampleInputText-<%= i %>" style="font-size:12px;" oninput="onTextareaInput(this, 'sample', 'Input', <%= i %>)"></textarea>
                <input type="file" name="sampleInputFile_<%= i %>" accept=".txt" id="sampleInputFile-<%= i %>" style="display:none">
              </div>
              <div class="form-group">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
                  <label style="margin:0; color:#a0a0b0; font-size:12px;">Thay thế Output (tuỳ chọn)</label>
                  <label class="upload-btn"><input type="file" accept=".txt" onchange="handleFileUpload(this, 'sampleOutput', <%= i %>)"> 📁 Upload .txt</label>
                </div>
                <div class="tc-file-info" id="sampleOutputFileInfo-<%= i %>" style="display:none; background:#1a1a2e; border:1px solid #00e5a0; border-radius:4px; padding:8px 12px; margin-bottom:6px; font-size:13px; color:#00e5a0;"></div>
                <textarea rows="2" placeholder="Hoặc nhập thủ công để thay thế..." id="sampleOutputText-<%= i %>" style="font-size:12px;" oninput="onTextareaInput(this, 'sample', 'Output', <%= i %>)"></textarea>
                <input type="file" name="sampleOutputFile_<%= i %>" accept=".txt" id="sampleOutputFile-<%= i %>" style="display:none">
              </div>
            </div>
          <% }) %>
        </div>
        <button type="button" class="btn-add-tc" onclick="addTestcase('sample')">+ Add Sample Test Case</button>
      </div>

      <div class="testcases-section">
        <h3>Hidden Test Cases</h3>
        <div id="hiddenTestcases">
          <% (problem.hiddenTestcases && problem.hiddenTestcases.length > 0 ? problem.hiddenTestcases : []).forEach((tc, i) => { %>
            <div class="testcase">
              <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
                <span style="color:#a0a0b0; font-size:13px;">Hidden #<%= i+1 %></span>
                <button type="button" class="btn-remove-tc" onclick="removeTestcase(this, 'hidden')">Remove</button>
              </div>
              <input type="hidden" name="keep_hidden_<%= i %>" value="1" id="keepHidden-<%= i %>">
              <div style="background:#1a1a2e; border:1px solid #2a2a4a; border-radius:4px; padding:10px 14px; margin-bottom:8px; font-size:13px; color:#a0a0b0;">
                ✓ Testcase đã có dữ liệu (<%= tc.input.split('\n').length %> dòng input, <%= tc.output.split('\n').length %> dòng output)
                <span style="color:#00e5a0; margin-left:8px; font-size:12px;">— Giữ nguyên nếu không thay thế</span>
              </div>
              <div class="form-group">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
                  <label style="margin:0; color:#a0a0b0; font-size:12px;">Thay thế Input (tuỳ chọn)</label>
                  <label class="upload-btn"><input type="file" accept=".txt" onchange="handleFileUpload(this, 'hiddenInput', <%= i %>)"> 📁 Upload .txt</label>
                </div>
                <div class="tc-file-info" id="hiddenInputFileInfo-<%= i %>" style="display:none; background:#1a1a2e; border:1px solid #00e5a0; border-radius:4px; padding:8px 12px; margin-bottom:6px; font-size:13px; color:#00e5a0;"></div>
                <textarea rows="2" placeholder="Hoặc nhập thủ công để thay thế..." id="hiddenInputText-<%= i %>" style="font-size:12px;" oninput="onTextareaInput(this, 'hidden', 'Input', <%= i %>)"></textarea>
                <input type="file" name="hiddenInputFile_<%= i %>" accept=".txt" id="hiddenInputFile-<%= i %>" style="display:none">
              </div>
              <div class="form-group">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
                  <label style="margin:0; color:#a0a0b0; font-size:12px;">Thay thế Output (tuỳ chọn)</label>
                  <label class="upload-btn"><input type="file" accept=".txt" onchange="handleFileUpload(this, 'hiddenOutput', <%= i %>)"> 📁 Upload .txt</label>
                </div>
                <div class="tc-file-info" id="hiddenOutputFileInfo-<%= i %>" style="display:none; background:#1a1a2e; border:1px solid #00e5a0; border-radius:4px; padding:8px 12px; margin-bottom:6px; font-size:13px; color:#00e5a0;"></div>
                <textarea rows="2" placeholder="Hoặc nhập thủ công để thay thế..." id="hiddenOutputText-<%= i %>" style="font-size:12px;" oninput="onTextareaInput(this, 'hidden', 'Output', <%= i %>)"></textarea>
                <input type="file" name="hiddenOutputFile_<%= i %>" accept=".txt" id="hiddenOutputFile-<%= i %>" style="display:none">
              </div>
            </div>
          <% }) %>
        </div>
        <button type="button" class="btn-add-tc" onclick="addTestcase('hidden')">+ Add Hidden Test Case</button>
      </div>

      <button type="submit" class="btn-submit">Save Changes</button>
    </form>
  </div>

  <script>
    const FILE_SIZE_LIMIT = 10 * 1024;
    let sampleCount = <%= (problem.sampleTestcases || problem.testcases || []).length %>;
    let hiddenCount = <%= (problem.hiddenTestcases && problem.hiddenTestcases.length > 0 ? problem.hiddenTestcases : []).length %>;

    // Khi người dùng nhập textarea thay thế → bỏ keep, gán name
    function onTextareaInput(el, type, field, index) {
      const keepEl = document.getElementById('keep' + (type === 'sample' ? 'Sample' : 'Hidden') + '-' + index);
      if (el.value.trim() !== '') {
        if (keepEl) keepEl.disabled = true;
        el.name = (type === 'sample' ? 'sample' : 'hidden') + field + '_' + index;
      } else {
        if (keepEl) keepEl.disabled = false;
        el.removeAttribute('name');
      }
    }

    function handleFileUpload(input, fieldName, index) {
      const file = input.files[0];
      if (!file) return;

      const infoEl = document.getElementById(fieldName + 'FileInfo-' + index);
      const textEl = document.getElementById(fieldName + 'Text-' + index);
      const fileInput = document.getElementById(fieldName + 'File-' + index);
      const type = fieldName.startsWith('sample') ? 'Sample' : 'Hidden';
      const keepEl = document.getElementById('keep' + type + '-' + index);

      const dt = new DataTransfer();
      dt.items.add(file);
      fileInput.files = dt.files;

      // Bỏ keep vì sẽ thay thế bằng file mới
      if (keepEl) keepEl.disabled = true;

      if (file.size > FILE_SIZE_LIMIT) {
        textEl.style.display = 'none';
        textEl.value = '';
        textEl.removeAttribute('name');
        infoEl.style.display = 'block';
        infoEl.textContent = '📄 ' + file.name + ' (' + (file.size / 1024).toFixed(1) + ' KB) — file uploaded, sẽ thay thế testcase cũ';
      } else {
        const reader = new FileReader();
        reader.onload = function(e) {
          textEl.style.display = '';
          textEl.setAttribute('name', fieldName + '_' + index);
          textEl.value = e.target.result;
          infoEl.style.display = 'none';
          fileInput.value = '';
        };
        reader.readAsText(file);
      }
    }

    function addTestcase(type) {
      const container = document.getElementById(type + 'Testcases');
      const index = type === 'sample' ? sampleCount++ : hiddenCount++;
      const label = type === 'sample' ? 'Sample' : 'Hidden';
      const fieldPrefix = type === 'sample' ? 'sample' : 'hidden';

      const div = document.createElement('div');
      div.className = 'testcase';
      div.innerHTML = `
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
          <span style="color:#a0a0b0; font-size:13px;">${label} #${index + 1}</span>
          <button type="button" class="btn-remove-tc" onclick="removeTestcase(this, '${type}')">Remove</button>
        </div>
        <div class="form-group">
          <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
            <label style="margin:0;">Input</label>
            <label class="upload-btn"><input type="file" accept=".txt" onchange="handleFileUploadNew(this, '${fieldPrefix}Input', ${index})"> 📁 Upload .txt</label>
          </div>
          <div class="tc-file-info" id="${fieldPrefix}InputFileInfo-${index}" style="display:none; background:#1a1a2e; border:1px solid #00e5a0; border-radius:4px; padding:8px 12px; margin-bottom:6px; font-size:13px; color:#00e5a0;"></div>
          <textarea name="${fieldPrefix}Input_${index}" rows="3" placeholder="${label} input..." id="${fieldPrefix}InputText-${index}"></textarea>
          <input type="file" name="${fieldPrefix}InputFile_${index}" accept=".txt" id="${fieldPrefix}InputFile-${index}" style="display:none">
        </div>
        <div class="form-group">
          <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
            <label style="margin:0;">Output</label>
            <label class="upload-btn"><input type="file" accept=".txt" onchange="handleFileUploadNew(this, '${fieldPrefix}Output', ${index})"> 📁 Upload .txt</label>
          </div>
          <div class="tc-file-info" id="${fieldPrefix}OutputFileInfo-${index}" style="display:none; background:#1a1a2e; border:1px solid #00e5a0; border-radius:4px; padding:8px 12px; margin-bottom:6px; font-size:13px; color:#00e5a0;"></div>
          <textarea name="${fieldPrefix}Output_${index}" rows="3" placeholder="${label} output..." id="${fieldPrefix}OutputText-${index}"></textarea>
          <input type="file" name="${fieldPrefix}OutputFile_${index}" accept=".txt" id="${fieldPrefix}OutputFile-${index}" style="display:none">
        </div>
      `;
      container.appendChild(div);
      renumberTestcases(type);
    }

    // Upload file cho testcase MỚI (không có keep)
    function handleFileUploadNew(input, fieldName, index) {
      const file = input.files[0];
      if (!file) return;
      const infoEl = document.getElementById(fieldName + 'FileInfo-' + index);
      const textEl = document.getElementById(fieldName + 'Text-' + index);
      const fileInput = document.getElementById(fieldName + 'File-' + index);
      const dt = new DataTransfer();
      dt.items.add(file);
      fileInput.files = dt.files;
      if (file.size > FILE_SIZE_LIMIT) {
        textEl.style.display = 'none';
        textEl.value = '';
        textEl.removeAttribute('name');
        infoEl.style.display = 'block';
        infoEl.textContent = '📄 ' + file.name + ' (' + (file.size / 1024).toFixed(1) + ' KB) — file uploaded';
      } else {
        const reader = new FileReader();
        reader.onload = function(e) {
          textEl.style.display = '';
          textEl.setAttribute('name', fieldName + '_' + index);
          textEl.value = e.target.result;
          infoEl.style.display = 'none';
          fileInput.value = '';
        };
        reader.readAsText(file);
      }
    }

    function removeTestcase(btn, type) {
      const container = document.getElementById(type + 'Testcases');
      if (container.children.length <= 1) return;
      btn.closest('.testcase').remove();
      renumberTestcases(type);
    }

    function renumberTestcases(type) {
      const container = document.getElementById(type + 'Testcases');
      const label = type === 'sample' ? 'Sample' : 'Hidden';
      Array.from(container.children).forEach((div, i) => {
        const span = div.querySelector('span');
        if (span) span.textContent = `${label} #${i + 1}`;
      });
    }
  </script>
</body>
</html>