<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Submission Result - DOJ</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/codemirror.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/theme/dracula.min.css">
</head>
<body>
  <nav class="navbar">
    <div class="nav-left">
      <a href="/" class="logo">DOJ</a>
      <a href="/problems" class="nav-link">Problems</a>
      <a href="/organizations" class="nav-link">Organizations</a>
      <a href="/leaderboard" class="nav-link">Leaderboard</a>
      <span id="adminNavLink" style="display:none;"><a href="/admin" class="nav-link">Admin</a></span>
    </div>
    <div class="nav-right">
      <span id="userNavLinks" style="display:none; align-items:center; gap:16px;">
        <a href="#" id="backToContestBtn" class="btn-register" style="text-decoration:none; display:none;">← Back to Contest</a>
        <a href="/notifications" class="notif-btn">
          🔔 <span class="notif-badge" id="notifBadge" style="display:none;">0</span>
        </a>
        <a href="#" class="nav-username" id="navUsername"></a>
        <a href="/logout" class="btn-logout">Logout</a>
      </span>
    </div>
  </nav>

  <div class="result-container" id="resultContainer" style="display:none;">
    <h2>Submission Result</h2>

    <div class="result-box">
      <div id="resultVerdict" class="result-status"></div>
      <p id="resultScore" class="result-score"></p>
      <p id="resultRuntime" style="color:#7a9ab0; font-size:13px; margin-top:8px; display:none;"></p>
    </div>

    <div style="font-size:13px; font-weight:600; color:#7a9ab0; text-transform:uppercase; letter-spacing:1px; margin-bottom:12px;">Test Cases</div>
    <div id="testCaseGrid" style="display:grid; grid-template-columns:repeat(3, minmax(0,1fr)); gap:8px; margin-bottom:24px;"></div>

    <div id="ceBlock" style="display:none; background:#141e26; border:1px solid #38bdf8; border-radius:6px; padding:14px; margin-bottom:24px;">
      <div style="font-size:12px; color:#38bdf8; font-weight:600; text-transform:uppercase; letter-spacing:1px; margin-bottom:8px;">Compilation Error</div>
      <pre id="ceOutput" style="color:#7a9ab0; font-size:12px; white-space:pre-wrap; word-break:break-all; margin:0;"></pre>
    </div>

    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
      <span style="font-size:13px; font-weight:600; color:#7a9ab0; text-transform:uppercase; letter-spacing:1px;">Your Code</span>
      <button id="copyBtn" onclick="copyCode()" style="background:transparent; border:1px solid #2a3e4e; color:#7a9ab0; padding:6px 14px; border-radius:4px; cursor:pointer; font-size:13px; transition:all 0.2s;">📋 Copy Code</button>
    </div>
    <div style="border:1px solid #2a3e4e; border-radius:4px; overflow:hidden; margin-bottom:24px;">
      <textarea id="codeView"></textarea>
    </div>

    <a id="backBtn" href="#" class="btn-submit" style="display:inline-block; text-decoration:none;">Back to Problem</a>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/codemirror.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/mode/clike/clike.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/mode/python/python.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/mode/javascript/javascript.min.js"></script>
  <script>
    const stored = sessionStorage.getItem('submissionResult');
    if (!stored) {
      window.location.href = '/';
    } else {
      const data = JSON.parse(stored);
      sessionStorage.removeItem('submissionResult');

      const { result, code, language, problemId, user, contestId } = data;

      // Navbar
      if (user) {
        const userNavLinks = document.getElementById('userNavLinks');
        userNavLinks.style.display = 'flex';
        document.getElementById('navUsername').textContent = user.username;
        document.getElementById('navUsername').href = '/profile/' + user.username;
        if (user.role === 'admin') {
          document.getElementById('adminNavLink').style.display = 'inline';
        }
        if (contestId) {
          const backToContestBtn = document.getElementById('backToContestBtn');
          backToContestBtn.href = '/contests/' + contestId;
          backToContestBtn.style.display = 'inline-block';
        }
        fetch('/notifications/count').then(r => r.json()).then(d => {
          if (d.count > 0) {
            const badge = document.getElementById('notifBadge');
            badge.textContent = d.count;
            badge.style.display = 'inline-block';
          }
        });
      }

      // Hiển thị trang kết quả
      document.getElementById('resultContainer').style.display = 'block';

      const verdictEl = document.getElementById('resultVerdict');
      verdictEl.textContent = result.verdict;
      verdictEl.className = 'result-status verdict-' + result.verdict.replace(/\s+/g, '').toLowerCase();

      document.getElementById('resultScore').textContent = 'Passed: ' + result.passedCount + ' / ' + result.total + ' test cases';

      if (result.execTime !== undefined) {
        const runtimeEl = document.getElementById('resultRuntime');
        runtimeEl.style.display = 'block';
        runtimeEl.innerHTML = '⏱ Runtime: <strong style="color:#ffffff;">' + result.execTime + 'ms</strong> &nbsp;·&nbsp; ' + (language === 'javascript' ? 'JavaScript (Node.js)' : language.toUpperCase());
      }

      // Test cases
      const grid = document.getElementById('testCaseGrid');
      const colorMap = { AC: '#00e5a0', WA: '#ff4444', TLE: '#f5a623', RE: '#f87171', CE: '#38bdf8' };
      result.details.forEach((tc, i) => {
        const color = colorMap[tc.status] || '#2a3e4e';
        const div = document.createElement('div');
        div.style.cssText = 'background:#141e26; border:1px solid ' + color + '; border-radius:6px; padding:10px 14px; display:flex; justify-content:space-between; align-items:center;';
        const timeStr = (tc.execTime !== undefined && tc.status !== 'TLE' && tc.status !== 'CE') ? '&nbsp;' + tc.execTime + 'ms' : '';
        div.innerHTML = '<span style="font-size:13px; color:#7a9ab0;">Test #' + (i + 1) + '</span><span style="font-size:12px; font-weight:600; color:' + color + ';">' + tc.status + timeStr + '</span>';
        grid.appendChild(div);
      });

      // CE block
      const ceDetail = result.details.find(tc => tc.status === 'CE');
      if (ceDetail) {
        document.getElementById('ceBlock').style.display = 'block';
        document.getElementById('ceOutput').textContent = ceDetail.output;
      }

      // Back button
      document.getElementById('backBtn').href = '/problems/' + problemId + (contestId ? '?contestId=' + contestId : '');

      // Code editor
      const modeMap = { cpp: 'text/x-c++src', c: 'text/x-csrc', python: 'text/x-python', javascript: 'text/javascript' };
      const editor = CodeMirror.fromTextArea(document.getElementById('codeView'), {
        mode: modeMap[language] || 'text/x-c++src',
        theme: 'dracula', lineNumbers: true, readOnly: true
      });
      editor.setValue(code);
      editor.setSize('100%', '400px');

      window.copyCode = function() {
        navigator.clipboard.writeText(editor.getValue()).then(() => {
          const btn = document.getElementById('copyBtn');
          btn.textContent = '✓ Copied!';
          btn.style.color = '#00e5a0';
          btn.style.borderColor = '#00e5a0';
          setTimeout(() => {
            btn.textContent = '📋 Copy Code';
            btn.style.color = '#7a9ab0';
            btn.style.borderColor = '#2a3e4e';
          }, 2000);
        });
      };
    }
  </script>
</body>
</html>