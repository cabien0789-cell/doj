<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Organization - DOJ</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
</head>
<body>
  <nav class="navbar">
    <div class="nav-left">
      <a href="/" class="logo">DOJ</a>
      <a href="/problems" class="nav-link">Problems</a>
      <a href="/organizations" class="nav-link">Organizations</a>
      <a href="/leaderboard" class="nav-link">Leaderboard</a>
      <% if (user && user.role === 'admin') { %>
        <a href="/admin" class="nav-link">Admin</a>
      <% } %>
    </div>
    <div class="nav-right">
      <a href="/notifications" class="notif-btn">
        🔔 <span class="notif-badge" id="notifBadge" style="display:none;">0</span>
      </a>
      <a href="/profile/<%= user.username %>" class="nav-username"><%= user.username %></a>
      <a href="/logout" class="btn-logout">Logout</a>
    </div>
  </nav>

  <div class="create-container">
    <h2>Edit Organization</h2>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="error-msg"><%= error %></div>
    <% } %>
    <form action="/organizations/<%= org.id %>/edit" method="POST">
      <div class="form-group">
        <label>Organization Name</label>
        <input type="text" name="name" value="<%= org.name %>" placeholder="Enter organization name" required />
      </div>
      <div class="form-group">
        <label>Description</label>
        <textarea name="description" rows="4" placeholder="Describe your organization..."><%= org.description || '' %></textarea>
      </div>
      <div class="form-group">
        <label>Visibility</label>
        <div style="display:flex; gap:12px; margin-top:8px; flex-wrap:wrap;">
          <label class="visibility-option <%= org.hidden ? '' : 'selected-public' %>" id="opt-public">
            <input type="radio" name="hidden" value="false" <%= org.hidden ? '' : 'checked' %> onchange="updateVisibility()">
            <div>
              <div style="color:#00e5a0; font-weight:600; font-size:14px;">🌐 Public</div>
              <div style="color:#7a9ab0; font-size:12px; margin-top:2px;">Contests are visible to everyone</div>
            </div>
          </label>
          <label class="visibility-option <%= org.hidden ? 'selected-private' : '' %>" id="opt-hidden">
            <input type="radio" name="hidden" value="true" <%= org.hidden ? 'checked' : '' %> onchange="updateVisibility()">
            <div>
              <div style="color:#f5a623; font-weight:600; font-size:14px;">🔒 Hidden</div>
              <div style="color:#7a9ab0; font-size:12px; margin-top:2px;">Members only can view content</div>
            </div>
          </label>
        </div>
      </div>
      <div style="display:flex; gap:12px; align-items:center;">
        <button type="submit" class="btn-submit">Save Changes</button>
        <a href="/organizations/<%= org.id %>" style="color:#7a9ab0; font-size:14px; text-decoration:none;">Cancel</a>
      </div>
    </form>
  </div>

  <script>
    function updateVisibility() {
      const isPublic = document.querySelector('input[name="hidden"][value="false"]').checked;
      document.getElementById('opt-public').className = isPublic ? 'visibility-option selected-public' : 'visibility-option';
      document.getElementById('opt-hidden').className = !isPublic ? 'visibility-option selected-private' : 'visibility-option';
    }

    fetch('/notifications/count').then(r => r.json()).then(data => {
      if (data.count > 0) {
        const badge = document.getElementById('notifBadge');
        badge.textContent = data.count;
        badge.style.display = 'inline-block';
      }
    });
  </script>
</body>
</html>