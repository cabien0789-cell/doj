<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= problem.title %> - DOJ</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/codemirror.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/theme/dracula.min.css">
</head>
<body>
  <nav class="navbar">
    <div class="nav-left">
      <a href="/" class="logo">DOJ</a>
      <a href="/problems" class="nav-link">Problems</a>
      <a href="/organizations" class="nav-link">Organizations</a>
      <a href="/leaderboard" class="nav-link">Leaderboard</a>
      <% if (user && user.role === 'admin') { %>
        <a href="/admin" class="nav-link">Admin</a>
      <% } %>
    </div>
    <div class="nav-right">
      <% if (contestId) { %>
        <a href="/contests/<%= contestId %>" class="btn-register" style="text-decoration:none;">← Back to Contest</a>
      <% } %>
      <% if (user) { %>
        <a href="/notifications" class="notif-btn">
          🔔 <span class="notif-badge" id="notifBadge" style="display:none;">0</span>
        </a>
        <a href="/profile/<%= user.username %>" class="nav-username"><%= user.username %></a>
        <a href="/logout" class="btn-logout">Logout</a>
      <% } else { %>
        <a href="/login" class="btn-login">Log In</a>
        <a href="/register" class="btn-register">Sign Up</a>
      <% } %>
    </div>
  </nav>

  <div class="problem-layout">
    <div class="problem-left">
      <div class="problem-header">
        <h2><%= problem.title %></h2>
        <span class="difficulty-<%= problem.difficulty.toLowerCase() %>"><%= problem.difficulty %></span>
        <% if (user && user.username === problem.author) { %>
          <a href="/problems/<%= problem.id %>/edit<%= contestId ? '?contestId=' + contestId : '' %>" style="color:#f5a623; font-size:13px; text-decoration:none; margin-left:8px;">✏ Edit</a>
          <form action="/problems/<%= problem.id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Delete this problem?')">
            <button type="submit" style="background:none; border:none; color:#ff4444; font-size:13px; cursor:pointer; margin-left:8px;">🗑 Delete</button>
          </form>
        <% } %>
      </div>
      <p class="problem-author">By <strong><%= problem.author %></strong></p>

      <% if (problem.tags && problem.tags.length > 0) { %>
        <div style="margin-bottom:20px; display:flex; flex-wrap:wrap; gap:8px;">
          <% problem.tags.forEach(tag => { %>
            <span class="tag-badge"><%= tag %></span>
          <% }) %>
        </div>
      <% } %>

      <div style="margin-bottom:24px; color:#a0a0b0; font-size:13px;">
        ⏱ Time Limit: <strong style="color:#ffffff;"><%= problem.timeLimit || 2 %>s</strong>
      </div>

      <div class="problem-section">
        <h3>Problem Statement</h3>
        <p><%= problem.statement %></p>
      </div>

      <div class="problem-section">
        <h3>Input Format</h3>
        <p><%= problem.inputFormat %></p>
      </div>

      <div class="problem-section">
        <h3>Output Format</h3>
        <p><%= problem.outputFormat %></p>
      </div>

      <% if (problem.constraints) { %>
        <div class="problem-section">
          <h3>Constraints</h3>
          <p><%= problem.constraints %></p>
        </div>
      <% } %>

      <div class="problem-section">
        <h3>Sample Test Cases</h3>
        <% (problem.sampleTestcases || problem.testcases || []).slice(0, 3).forEach((tc, i) => { %>
          <div class="testcase-display">
            <div class="tc-block">
              <div class="tc-label" style="display:flex; justify-content:space-between; align-items:center;">
                <span>Input <%= i + 1 %></span>
                <button onclick="copyText(this, '<%= i %>-input')" style="background:none; border:none; color:#a0a0b0; cursor:pointer; font-size:11px; padding:2px 6px;">📋 Copy</button>
              </div>
              <pre id="tc-<%= i %>-input"><%= tc.input %></pre>
            </div>
            <div class="tc-block">
              <div class="tc-label" style="display:flex; justify-content:space-between; align-items:center;">
                <span>Output <%= i + 1 %></span>
                <button onclick="copyText(this, '<%= i %>-output')" style="background:none; border:none; color:#a0a0b0; cursor:pointer; font-size:11px; padding:2px 6px;">📋 Copy</button>
              </div>
              <pre id="tc-<%= i %>-output"><%= tc.output %></pre>
            </div>
          </div>
        <% }) %>
      </div>

      <% if (problem.explanation) { %>
        <div class="problem-section">
          <h3>Explanation</h3>
          <p><%= problem.explanation %></p>
        </div>
      <% } %>

      <% if (mySubmissions && mySubmissions.length > 0) { %>
        <div class="problem-section">
          <h3>My Recent Submissions</h3>
          <table class="problems-table">
            <thead>
              <tr>
                <th>Time</th>
                <th>Language</th>
                <th>Verdict</th>
                <th>Score</th>
              </tr>
            </thead>
            <tbody>
              <% mySubmissions.forEach(s => { %>
                <tr>
                  <td style="color:#a0a0b0; font-size:13px;"><%= new Date(s.submittedAt).toLocaleString('en-GB', { hour12: false }) %></td>
                  <td><%= s.language === 'javascript' ? 'JavaScript' : s.language.toUpperCase() %></td>
                  <td class="verdict-<%= s.verdict.replace(/\s+/g,'').toLowerCase() %>"><%= s.verdict %></td>
                  <td><%= s.passedCount %>/<%= s.total %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <div class="problem-right">
      <% if (user) { %>
        <div id="submitErrorBox" style="display:none; background:#2a1a1a; border:1px solid #ff4444; border-radius:6px; padding:12px 16px; margin-bottom:14px; color:#ff4444; font-size:13px;"></div>

        <div class="editor-header">
          <select name="language" class="language-select" id="languageSelect">
            <option value="cpp">C++</option>
            <option value="c">C</option>
            <option value="python">Python</option>
            <option value="javascript">JavaScript (Node.js)</option>
          </select>
        </div>
        <div id="editorWrapper">
          <textarea name="code" id="codeArea"></textarea>
        </div>
        <div class="editor-actions">
          <button type="button" class="btn-run" id="runBtn" onclick="runCode()">▶ Run Code</button>
          <button type="button" class="btn-submit" id="submitBtn" onclick="submitCode()">Submit</button>
        </div>

        <div id="runPanel" style="display:none;">
          <div class="run-panel">
            <div class="run-panel-header">
              <span>Custom Input</span>
              <button onclick="closeRunPanel()" style="background:none; border:none; color:#a0a0b0; cursor:pointer; font-size:18px;">×</button>
            </div>
            <textarea id="customInput" class="run-input" placeholder="Enter your input here..."></textarea>
            <button onclick="executeRun()" class="btn-execute" id="executeBtn">▶ Execute</button>
            <div class="run-output" id="runOutput" style="display:none;">
              <div class="run-output-label">Output</div>
              <pre id="runOutputText"></pre>
            </div>
          </div>
        </div>

      <% } else { %>
        <div class="login-to-submit">
          <p>Please <a href="/login">log in</a> to submit your solution.</p>
        </div>
      <% } %>
    </div>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/codemirror.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/mode/clike/clike.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/mode/python/python.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/mode/javascript/javascript.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/addon/edit/closebrackets.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/addon/edit/matchbrackets.min.js"></script>
  <script>
    const defaultCode = {
      cpp: `#include <bits/stdc++.h>\nusing namespace std;\n\nint main() {\n    \n    return 0;\n}`,
      c: `#include <stdio.h>\n\nint main() {\n    \n    return 0;\n}`,
      python: `import sys\ninput = sys.stdin.readline\n\n`,
      javascript: `const lines = require('fs').readFileSync('/dev/stdin','utf8').split('\\n');\nlet idx = 0;\n\n`
    };

    const editor = CodeMirror.fromTextArea(document.getElementById('codeArea'), {
      mode: 'text/x-c++src', theme: 'dracula', lineNumbers: true,
      autoCloseBrackets: true, matchBrackets: true,
      indentUnit: 4, tabSize: 4, indentWithTabs: false, lineWrapping: false,
    });

    editor.setValue(defaultCode.cpp);
    editor.setSize('100%', '100%');

    const modeMap = { cpp: 'text/x-c++src', c: 'text/x-csrc', python: 'text/x-python', javascript: 'text/javascript' };

    document.getElementById('languageSelect').addEventListener('change', function() {
      editor.setOption('mode', modeMap[this.value]);
      editor.setValue(defaultCode[this.value]);
    });

    let pollingInterval = null;

    async function submitCode() {
      editor.save();
      const code = document.getElementById('codeArea').value;
      const language = document.getElementById('languageSelect').value;
      const submitBtn = document.getElementById('submitBtn');
      const runBtn = document.getElementById('runBtn');
      const errorBox = document.getElementById('submitErrorBox');

      errorBox.style.display = 'none';
      submitBtn.textContent = 'Judging...';
      submitBtn.disabled = true;
      runBtn.disabled = true;

      try {
        const res = await fetch('/problems/<%= problem.id %>/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ code, language })
        });
        const data = await res.json();

        if (data.error) {
          errorBox.textContent = '⚠ ' + data.error;
          errorBox.style.display = 'block';
          submitBtn.textContent = 'Submit';
          submitBtn.disabled = false;
          runBtn.disabled = false;
          return;
        }

        const submissionId = data.submissionId;
        const contestIdValue = '<%- contestId || "" %>';
        const pendingData = {
          code,
          language,
          user: { username: '<%= user.username %>', role: '<%= user.role %>' },
          contestId: contestIdValue || null
        };

        pollingInterval = setInterval(async () => {
          try {
            const statusRes = await fetch('/submissions/' + submissionId + '/status');
            const statusData = await statusRes.json();
            if (statusData.status === 'done') {
              clearInterval(pollingInterval);
              pendingData.result = statusData.result;
              pendingData.problemId = statusData.problemId;
              pendingData.language = statusData.language;
              sessionStorage.setItem('submissionResult', JSON.stringify(pendingData));
              window.location.href = '/submission-result';
            } else if (statusData.status === 'error') {
              clearInterval(pollingInterval);
              errorBox.textContent = '⚠ An error occurred. Please try again.';
              errorBox.style.display = 'block';
              submitBtn.textContent = 'Submit';
              submitBtn.disabled = false;
              runBtn.disabled = false;
            }
          } catch (e) {
            clearInterval(pollingInterval);
            errorBox.textContent = '⚠ An error occurred. Please try again.';
            errorBox.style.display = 'block';
            submitBtn.textContent = 'Submit';
            submitBtn.disabled = false;
            runBtn.disabled = false;
          }
        }, 2000);

      } catch (e) {
        errorBox.textContent = '⚠ An error occurred. Please try again.';
        errorBox.style.display = 'block';
        submitBtn.textContent = 'Submit';
        submitBtn.disabled = false;
        runBtn.disabled = false;
      }
    }

    function runCode() {
      document.getElementById('runPanel').style.display = 'block';
      document.getElementById('runOutput').style.display = 'none';
    }

    function closeRunPanel() {
      document.getElementById('runPanel').style.display = 'none';
    }

    async function executeRun() {
      editor.save();
      const code = document.getElementById('codeArea').value;
      const language = document.getElementById('languageSelect').value;
      const input = document.getElementById('customInput').value;
      const btn = document.getElementById('executeBtn');
      btn.textContent = 'Running...';
      btn.disabled = true;
      try {
        const res = await fetch('/run', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ code, language, input })
        });
        const data = await res.json();
        document.getElementById('runOutput').style.display = 'block';
        document.getElementById('runOutputText').textContent = data.output || data.error || 'No output';
        document.getElementById('runOutputText').style.color = data.error ? '#ff4444' : '#00e5a0';
      } catch (e) {
        document.getElementById('runOutput').style.display = 'block';
        document.getElementById('runOutputText').textContent = 'Error: ' + e.message;
        document.getElementById('runOutputText').style.color = '#ff4444';
      }
      btn.textContent = '▶ Execute';
      btn.disabled = false;
    }

    function copyText(btn, id) {
      const text = document.getElementById('tc-' + id).textContent;
      navigator.clipboard.writeText(text).then(() => {
        btn.textContent = '✓ Copied';
        btn.style.color = '#00e5a0';
        setTimeout(() => {
          btn.textContent = '📋 Copy';
          btn.style.color = '#a0a0b0';
        }, 2000);
      });
    }

    <% if (user) { %>
    fetch('/notifications/count').then(r => r.json()).then(data => {
      if (data.count > 0) {
        const badge = document.getElementById('notifBadge');
        badge.textContent = data.count;
        badge.style.display = 'inline-block';
      }
    });
    <% } %>
  </script>
</body>
</html>