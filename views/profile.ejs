<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= targetUser.username %> - DOJ</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
</head>
<body>
  <nav class="navbar">
    <div class="nav-left">
      <a href="/" class="logo">DOJ</a>
      <a href="/problems" class="nav-link">Problems</a>
      <a href="/organizations" class="nav-link">Organizations</a>
      <a href="/leaderboard" class="nav-link">Leaderboard</a>
      <% if (user && user.role === 'admin') { %>
        <a href="/admin" class="nav-link">Admin</a>
      <% } %>
    </div>
    <div class="nav-right">
      <% if (user) { %>
        <a href="/notifications" class="notif-btn">
          🔔 <span class="notif-badge" id="notifBadge" style="display:none;">0</span>
        </a>
        <a href="/profile/<%= user.username %>" class="nav-username"><%= user.username %></a>
        <a href="/logout" class="btn-logout">Logout</a>
      <% } else { %>
        <a href="/login" class="btn-login">Log In</a>
        <a href="/register" class="btn-register">Sign Up</a>
      <% } %>
    </div>
  </nav>

  <div class="problems-container">
    <div class="profile-header">
      <div class="profile-avatar"><%= targetUser.username.charAt(0).toUpperCase() %></div>
      <div class="profile-info">
        <h2><%= targetUser.username %></h2>
        <p style="color:#7a9ab0; font-size:14px; margin-bottom:4px;"><%= targetUser.email %></p>
        <p style="color:#7a9ab0; font-size:13px;">
          Member since <strong style="color:#ffffff;"><%= new Date(targetUser.createdAt).toLocaleDateString('en-GB') %></strong>
        </p>
        <% if (user && user.username === targetUser.username) { %>
          <a href="/change-password" style="display:inline-block; margin-top:10px; color:#7a9ab0; font-size:13px; text-decoration:none; border:1px solid #2a3e4e; padding:5px 12px; border-radius:4px;">🔒 Change Password</a>
        <% } %>
      </div>
    </div>

    <div class="profile-stats">
      <div class="profile-stat-card">
        <span class="profile-stat-number"><%= stats.solved %></span>
        <span class="profile-stat-label">Problems Solved</span>
      </div>
      <div class="profile-stat-card">
        <span class="profile-stat-number"><%= stats.totalSubmissions %></span>
        <span class="profile-stat-label">Total Submissions</span>
      </div>
      <div class="profile-stat-card">
        <span class="profile-stat-number" style="color:#00e5a0;"><%= stats.accepted %></span>
        <span class="profile-stat-label">Accepted</span>
      </div>
      <div class="profile-stat-card">
        <span class="profile-stat-number" style="color:#ff4444;"><%= stats.wrongAnswer %></span>
        <span class="profile-stat-label">Wrong Answer</span>
      </div>
      <div class="profile-stat-card">
        <span class="profile-stat-number" style="color:#f5a623;"><%= stats.tle %></span>
        <span class="profile-stat-label">Time Limit Exceeded</span>
      </div>
      <div class="profile-stat-card">
        <span class="profile-stat-number" style="color:#38bdf8;"><%= stats.ce %></span>
        <span class="profile-stat-label">Compilation Error</span>
      </div>
    </div>

    <% if (stats.totalSubmissions > 0 && stats.langStats) { %>
      <div style="background-color:#141e26; border:1px solid #2a3e4e; border-radius:8px; padding:20px 24px; margin-bottom:32px;">
        <div style="font-size:14px; font-weight:600; color:#7a9ab0; text-transform:uppercase; letter-spacing:1px; margin-bottom:16px;">Languages Used</div>
        <div style="display:flex; gap:12px; flex-wrap:wrap;">
          <% const langColors = { cpp: '#00e5a0', c: '#38bdf8', python: '#facc15' }; %>
          <% Object.entries(stats.langStats).sort((a,b) => b[1]-a[1]).forEach(([lang, count]) => { %>
            <div style="display:flex; align-items:center; gap:8px; background:#0e1820; padding:8px 16px; border-radius:20px; border:1px solid #2a3e4e;">
              <span style="width:10px; height:10px; border-radius:50%; background:<%= langColors[lang] || '#00e5a0' %>; display:inline-block;"></span>
              <span style="color:#e0eaf0; font-size:14px; font-weight:600;"><%= lang.toUpperCase() %></span>
              <span style="color:#7a9ab0; font-size:13px;"><%= count %> submissions</span>
              <span style="color:#7a9ab0; font-size:12px;">(<%= Math.round(count / stats.totalSubmissions * 100) %>%)</span>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <div style="display:flex; gap:8px; margin-bottom:24px;">
      <button onclick="showTab('submissions')" id="tab-submissions" class="tab-btn tab-active">Recent Submissions</button>
      <% if (user && user.username === targetUser.username) { %>
        <button onclick="showTab('myproblems')" id="tab-myproblems" class="tab-btn">My Problems (<%= myProblems.length %>)</button>
      <% } %>
    </div>

    <div id="section-submissions">
      <table class="problems-table">
        <thead>
          <tr>
            <th>Time</th>
            <th>Problem</th>
            <th>Language</th>
            <th>Verdict</th>
            <th>Score</th>
            <% if (user && user.username === targetUser.username) { %>
              <th>Code</th>
            <% } %>
          </tr>
        </thead>
        <tbody>
          <% if (recentSubmissions.length === 0) { %>
            <tr><td colspan="6" class="no-problems">No submissions yet.</td></tr>
          <% } else { %>
            <% recentSubmissions.forEach(s => { %>
              <tr>
                <td style="color:#7a9ab0; font-size:13px;"><%= new Date(s.submittedAt).toLocaleString('en-GB', { hour12: false }) %></td>
                <td><a href="/problems/<%= s.problemId %>"><%= s.problemTitle %></a></td>
                <td><%= s.language.toUpperCase() %></td>
                <td class="verdict-<%= s.verdict.replace(/\s+/g,'').toLowerCase() %>"><%= s.verdict %></td>
                <td><%= s.passedCount %>/<%= s.total %></td>
                <% if (user && user.username === targetUser.username) { %>
                  <td><a href="/submissions/<%= s.id %>" style="color:#00e5a0; text-decoration:none; font-size:13px;">View</a></td>
                <% } %>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>

    <% if (user && user.username === targetUser.username) { %>
    <div id="section-myproblems" style="display:none;">
      <div style="margin-bottom:16px;">
        <input type="text" id="myProblemSearch" placeholder="Search my problems..." class="filter-input" oninput="filterMyProblems()" />
      </div>
      <% if (myProblems.length === 0) { %>
        <div style="text-align:center; color:#7a9ab0; padding:40px 0;">No problems yet. Create problems inside your contests.</div>
      <% } else { %>
        <table class="problems-table">
          <thead>
            <tr>
              <th>Title</th>
              <th>Difficulty</th>
              <th>Tags</th>
              <th>Created</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody id="myProblemsBody">
            <% myProblems.forEach(p => { %>
              <tr class="my-problem-row" data-title="<%= p.title.toLowerCase() %>">
                <td><a href="/problems/<%= p.id %>"><%= p.title %></a></td>
                <td class="difficulty-<%= p.difficulty.toLowerCase() %>"><%= p.difficulty %></td>
                <td style="color:#7a9ab0; font-size:13px;">
                  <% if (p.tags && p.tags.length > 0) { %>
                    <%= p.tags.slice(0,2).join(', ') %><%= p.tags.length > 2 ? ' +' + (p.tags.length-2) : '' %>
                  <% } else { %>—<% } %>
                </td>
                <td style="color:#7a9ab0; font-size:13px;"><%= new Date(p.createdAt).toLocaleDateString('en-GB') %></td>
                <td>
                  <button onclick="removeFromProfile('<%= p.id %>', '<%= p.title.replace(/'/g, "\\'") %>')" style="background:transparent; color:#ff4444; border:1px solid #ff4444; padding:5px 12px; border-radius:4px; cursor:pointer; font-size:12px;">Remove</button>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
    <% } %>
  </div>

  <script>
    function showTab(tab) {
      ['submissions', 'myproblems'].forEach(t => {
        const section = document.getElementById('section-' + t);
        const btn = document.getElementById('tab-' + t);
        if (section) section.style.display = t === tab ? 'block' : 'none';
        if (btn) btn.className = t === tab ? 'tab-btn tab-active' : 'tab-btn';
      });
    }

    function filterMyProblems() {
      const search = document.getElementById('myProblemSearch').value.toLowerCase();
      document.querySelectorAll('.my-problem-row').forEach(row => {
        row.style.display = row.dataset.title.includes(search) ? '' : 'none';
      });
    }

    async function removeFromProfile(id, title) {
      if (!confirm(`Remove "${title}" from My Problems? This will not affect the problem in any contest.`)) return;
      const res = await fetch('/problems/' + id + '/remove-from-profile', { method: 'POST' });
      if (res.ok) {
        const row = document.querySelector(`.my-problem-row[data-title="${title.toLowerCase()}"]`);
        if (row) row.remove();
      }
    }

    <% if (user) { %>
    fetch('/notifications/count').then(r => r.json()).then(data => {
      if (data.count > 0) {
        const badge = document.getElementById('notifBadge');
        badge.textContent = data.count;
        badge.style.display = 'inline-block';
      }
    });
    <% } %>
  </script>
</body>
</html>