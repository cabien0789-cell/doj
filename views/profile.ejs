<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= targetUser.username %> - DOJ</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
</head>
<body>
  <nav class="navbar">
    <div class="nav-left">
      <a href="/" class="logo">DOJ</a>
      <a href="/problems" class="nav-link">Problems</a>
      <a href="/organizations" class="nav-link">Organizations</a>
      <a href="/leaderboard" class="nav-link">Leaderboard</a>
    </div>
    <div class="nav-right">
      <% if (user) { %>
        <a href="/problems/create" class="btn-register">+ Create</a>
        <a href="/profile/<%= user.username %>" class="nav-username"><%= user.username %></a>
        <a href="/logout" class="btn-logout">Logout</a>
      <% } else { %>
        <a href="/login" class="btn-login">Log In</a>
        <a href="/register" class="btn-register">Sign Up</a>
      <% } %>
    </div>
  </nav>

  <div class="problems-container">

    <!-- Profile Header -->
    <div class="profile-header">
      <div class="profile-avatar"><%= targetUser.username.charAt(0).toUpperCase() %></div>
      <div class="profile-info">
        <h2><%= targetUser.username %></h2>
        <p style="color:#a0a0b0; font-size:14px; margin-bottom:4px;"><%= targetUser.email %></p>
        <p style="color:#a0a0b0; font-size:13px;">
          Member since <strong style="color:#ffffff;"><%= new Date(targetUser.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></strong>
        </p>
        <% if (user && user.username === targetUser.username) { %>
          <a href="/change-password" style="display:inline-block; margin-top:10px; color:#a0a0b0; font-size:13px; text-decoration:none; border:1px solid #2a2a4a; padding:5px 12px; border-radius:4px;">🔒 Change Password</a>
        <% } %>
      </div>
    </div>

    <!-- Stats Cards -->
    <div class="profile-stats">
      <div class="profile-stat-card">
        <span class="profile-stat-number"><%= stats.solved %></span>
        <span class="profile-stat-label">Problems Solved</span>
      </div>
      <div class="profile-stat-card">
        <span class="profile-stat-number"><%= stats.totalSubmissions %></span>
        <span class="profile-stat-label">Total Submissions</span>
      </div>
      <div class="profile-stat-card">
        <span class="profile-stat-number" style="color:#00e5a0;"><%= stats.accepted %></span>
        <span class="profile-stat-label">Accepted</span>
      </div>
      <div class="profile-stat-card">
        <span class="profile-stat-number" style="color:#ff4444;"><%= stats.wrongAnswer %></span>
        <span class="profile-stat-label">Wrong Answer</span>
      </div>
      <div class="profile-stat-card">
        <span class="profile-stat-number" style="color:#f5a623;"><%= stats.tle %></span>
        <span class="profile-stat-label">Time Limit Exceeded</span>
      </div>
      <div class="profile-stat-card">
        <span class="profile-stat-number" style="color:#a0a0b0;"><%= stats.ce %></span>
        <span class="profile-stat-label">Compilation Error</span>
      </div>
    </div>

    <!-- Language Stats -->
    <% if (stats.totalSubmissions > 0 && stats.langStats) { %>
      <div style="background-color:#0f0f23; border:1px solid #2a2a4a; border-radius:8px; padding:20px 24px; margin-bottom:32px;">
        <div style="font-size:14px; font-weight:600; color:#a0a0b0; text-transform:uppercase; letter-spacing:1px; margin-bottom:16px;">Languages Used</div>
        <div style="display:flex; gap:12px; flex-wrap:wrap;">
          <% const langColors = { cpp: '#60a5fa', c: '#a78bfa', java: '#f97316', python: '#facc15' }; %>
          <% Object.entries(stats.langStats).sort((a,b) => b[1]-a[1]).forEach(([lang, count]) => { %>
            <div style="display:flex; align-items:center; gap:8px; background:#1a1a2e; padding:8px 16px; border-radius:20px; border:1px solid #2a2a4a;">
              <span style="width:10px; height:10px; border-radius:50%; background:<%= langColors[lang] || '#00e5a0' %>; display:inline-block;"></span>
              <span style="color:#ffffff; font-size:14px; font-weight:600;"><%= lang.toUpperCase() %></span>
              <span style="color:#a0a0b0; font-size:13px;"><%= count %> submissions</span>
              <span style="color:#a0a0b0; font-size:12px;">(<%= Math.round(count / stats.totalSubmissions * 100) %>%)</span>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <!-- Recent Submissions -->
    <div class="problems-header" style="margin-top:8px;">
      <h2>Recent Submissions</h2>
    </div>

    <table class="problems-table">
      <thead>
        <tr>
          <th>Time</th>
          <th>Problem</th>
          <th>Language</th>
          <th>Verdict</th>
          <th>Score</th>
          <% if (user && user.username === targetUser.username) { %>
            <th>Code</th>
          <% } %>
        </tr>
      </thead>
      <tbody>
        <% if (recentSubmissions.length === 0) { %>
          <tr>
            <td colspan="6" class="no-problems">No submissions yet.</td>
          </tr>
        <% } else { %>
          <% recentSubmissions.forEach(s => { %>
            <tr>
              <td style="color:#a0a0b0; font-size:13px;"><%= new Date(s.submittedAt).toLocaleString() %></td>
              <td><a href="/problems/<%= s.problemId %>"><%= s.problemTitle %></a></td>
              <td><%= s.language.toUpperCase() %></td>
              <td class="verdict-<%= s.verdict.replace(/\s+/g,'').toLowerCase() %>"><%= s.verdict %></td>
              <td><%= s.passedCount %>/<%= s.total %></td>
              <% if (user && user.username === targetUser.username) { %>
                <td><a href="/submissions/<%= s.id %>" style="color:#00e5a0; text-decoration:none; font-size:13px;">View</a></td>
              <% } %>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>

  </div>
</body>
</html>