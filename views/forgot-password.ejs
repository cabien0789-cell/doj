<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Forgot Password - DOJ</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="nav-left">
      <a href="/" class="logo">DOJ</a>
    </div>
    <div class="nav-right">
      <a href="/login" class="btn-login">Log In</a>
      <a href="/register" class="btn-register">Sign Up</a>
    </div>
  </nav>

  <div class="auth-container">
    <div class="auth-box">
      <h2>Forgot Password</h2>
      <p class="verify-desc">Enter your email address and we'll send you a reset code.</p>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="error-msg"><%= error %></div>
      <% } %>
      <form action="/forgot-password" method="POST">
        <div class="form-group">
          <label>Email</label>
          <input type="email" name="email" placeholder="Enter your email" required />
        </div>
        <button type="submit" class="btn-submit">Send Reset Code</button>
      </form>
      <p class="auth-switch"><a href="/login">Back to Log In</a></p>
    </div>
  </div>
</body>
</html>