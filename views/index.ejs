<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DOJ - Dary Online Judge</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
</head>
<body>
  <nav class="navbar">
    <div class="nav-left">
      <a href="/" class="logo">DOJ</a>
      <a href="/problems" class="nav-link">Problems</a>
      <a href="/organizations" class="nav-link">Organizations</a>
      <a href="/leaderboard" class="nav-link">Leaderboard</a>
      <% if (user && user.role === 'admin') { %>
        <a href="/admin" class="nav-link">Admin</a>
      <% } %>
    </div>
    <div class="nav-right">
      <% if (user) { %>
        <a href="/notifications" class="notif-btn">
          🔔 <span class="notif-badge" id="notifBadge" style="display:none;">0</span>
        </a>
        <a href="/profile/<%= user.username %>" class="nav-username"><%= user.username %></a>
        <a href="/logout" class="btn-logout">Logout</a>
      <% } else { %>
        <a href="/login" class="btn-login">Log In</a>
        <a href="/register" class="btn-register">Sign Up</a>
      <% } %>
    </div>
  </nav>

  <div class="hero">
    <div class="hero-content">
      <h1>Dary Online Judge</h1>
      <p>Practice coding. Solve problems. Compete with others.</p>
      <% if (!user) { %>
        <a href="/register" class="btn-hero">Get Started</a>
      <% } %>
    </div>
  </div>

  <div class="home-container">
    <div class="home-section">
      <div class="home-section-header">
        <h2>🏆 Recent Contests</h2>
        <a href="/organizations" style="color:#00e5a0; font-size:13px; text-decoration:none;">View all →</a>
      </div>
      <% if (recentContests.length === 0) { %>
        <div style="text-align:center; color:#a0a0b0; padding:40px 0;">No contests yet.</div>
      <% } else { %>
        <% recentContests.forEach(contest => { %>
          <div style="background:#0f0f23; border:1px solid #2a2a4a; border-radius:8px; padding:16px 20px; margin-bottom:10px; display:flex; justify-content:space-between; align-items:center; transition:border-color 0.2s;" onmouseenter="this.style.borderColor='#00e5a0'" onmouseleave="this.style.borderColor='#2a2a4a'">
            <div>
              <div style="display:flex; align-items:center; gap:8px; margin-bottom:6px;">
                <a href="/contests/<%= contest.id %>" style="color:#ffffff; font-weight:600; text-decoration:none; font-size:15px;"><%= contest.name %></a>
                <% if (contest.visibility === 'private') { %>
                  <span style="color:#f5a623; font-size:11px; padding:2px 8px; border:1px solid #f5a623; border-radius:20px;">🔒 Private</span>
                <% } else { %>
                  <span style="color:#a0a0b0; font-size:11px; padding:2px 8px; border:1px solid #2a2a4a; border-radius:20px;">🌐 Public</span>
                <% } %>
              </div>
              <% if (contest.noTimeLimit) { %>
                <p style="color:#00e5a0; font-size:12px; margin:0;">No time limit</p>
              <% } else { %>
                <%
                  const cTz = contest.timezone === 'Vietnam' ? 'Asia/Ho_Chi_Minh' : 'UTC';
                  const cTzLabel = contest.timezone === 'Vietnam' ? '(Vietnam UTC+7)' : '(UTC)';
                  const cStart = new Date(contest.startTimeUTC || contest.startTime).toLocaleString('en-GB', { timeZone: cTz });
                  const cEnd = new Date(contest.endTimeUTC || contest.endTime).toLocaleString('en-GB', { timeZone: cTz });
                %>
                <p style="color:#a0a0b0; font-size:12px; margin:0;"><%= cStart %> → <%= cEnd %> <%= cTzLabel %></p>
              <% } %>
            </div>
            <% const nowHome = new Date(); %>
            <% if (contest.noTimeLimit) { %>
              <span class="status-live">● Live</span>
            <% } else if (nowHome < new Date(contest.startTimeUTC || contest.startTime)) { %>
              <span class="status-upcoming">Upcoming</span>
            <% } else if (nowHome > new Date(contest.endTimeUTC || contest.endTime)) { %>
              <span class="status-ended">Ended</span>
            <% } else { %>
              <span class="status-live">● Live</span>
            <% } %>
          </div>
        <% }) %>
      <% } %>
    </div>

    <div class="home-section">
      <div class="home-section-header">
        <h2>👑 Top Users</h2>
        <a href="/leaderboard" style="color:#00e5a0; font-size:13px; text-decoration:none;">View all →</a>
      </div>
      <% if (topUsers.length === 0) { %>
        <div style="text-align:center; color:#a0a0b0; padding:40px 0;">No data yet.</div>
      <% } else { %>
        <table class="problems-table">
          <thead>
            <tr>
              <th>Rank</th>
              <th>Username</th>
              <th>Solved</th>
              <th>Acceptance</th>
            </tr>
          </thead>
          <tbody>
            <% topUsers.forEach((u, index) => { %>
              <tr>
                <td>
                  <% if (index === 0) { %><span style="color:#f5c518; font-weight:700; font-size:18px;">🥇</span>
                  <% } else if (index === 1) { %><span style="color:#a0a0b0; font-weight:700; font-size:18px;">🥈</span>
                  <% } else if (index === 2) { %><span style="color:#cd7f32; font-weight:700; font-size:18px;">🥉</span>
                  <% } else { %><span style="color:#a0a0b0;"><%= index + 1 %></span><% } %>
                </td>
                <td>
                  <a href="/profile/<%= u.username %>" style="color:#ffffff; text-decoration:none; font-weight:600;">
                    <% if (user && user.username === u.username) { %>
                      <span style="color:#00e5a0;"><%= u.username %></span>
                      <span style="color:#a0a0b0; font-size:12px;"> (you)</span>
                    <% } else { %>
                      <%= u.username %>
                    <% } %>
                  </a>
                </td>
                <td style="color:#00e5a0; font-weight:700;"><%= u.solved %></td>
                <td style="color:#f5a623;">
                  <%= u.totalSubmissions > 0 ? Math.round(u.accepted / u.totalSubmissions * 100) + '%' : '—' %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>

  <% if (user) { %>
  <script>
    fetch('/notifications/count').then(r => r.json()).then(data => {
      if (data.count > 0) {
        const badge = document.getElementById('notifBadge');
        badge.textContent = data.count;
        badge.style.display = 'inline-block';
      }
    });
  </script>
  <% } %>
</body>
</html>