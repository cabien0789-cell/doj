<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DOJ - Dary Online Judge</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
</head>
<body>
  <nav class="navbar">
    <div class="nav-left">
      <a href="/" class="logo">DOJ</a>
      <a href="/problems" class="nav-link">Problems</a>
      <a href="/organizations" class="nav-link">Organizations</a>
      <a href="/leaderboard" class="nav-link">Leaderboard</a>
    </div>
    <div class="nav-right">
      <% if (user) { %>
        <a href="/problems/create" class="btn-register">+ Create</a>
        <a href="/notifications" class="notif-btn" id="notifBtn">
          🔔 <span class="notif-badge" id="notifBadge" style="display:none;">0</span>
        </a>
        <a href="/profile/<%= user.username %>" class="nav-username"><%= user.username %></a>
        <a href="/logout" class="btn-logout">Logout</a>
      <% } else { %>
        <a href="/login" class="btn-login">Log In</a>
        <a href="/register" class="btn-register">Sign Up</a>
      <% } %>
    </div>
  </nav>

  <div class="hero">
    <div class="hero-content">
      <h1>Dary Online Judge</h1>
      <p>Practice coding. Solve problems. Compete with others.</p>
      <% if (!user) { %>
        <a href="/register" class="btn-hero">Get Started</a>
      <% } %>
    </div>
  </div>

  <div class="stats-bar">
    <div class="stat-item">
      <span class="stat-number"><%= stats.problems %></span>
      <span class="stat-label">Problems</span>
    </div>
    <div class="stat-item">
      <span class="stat-number"><%= stats.users %></span>
      <span class="stat-label">Users</span>
    </div>
    <div class="stat-item">
      <span class="stat-number"><%= stats.submissions %></span>
      <span class="stat-label">Submissions</span>
    </div>
  </div>

  <div class="features">
    <div class="feature-card">
      <h3>Solve Problems</h3>
      <p>Challenge yourself with algorithmic problems of all difficulty levels.</p>
    </div>
    <div class="feature-card">
      <h3>Create Problems</h3>
      <p>Create and share your own problems with the community.</p>
    </div>
    <div class="feature-card">
      <h3>Compete</h3>
      <p>Join organizations and participate in contests.</p>
    </div>
  </div>

  <% if (user) { %>
  <script>
    fetch('/notifications/count')
      .then(r => r.json())
      .then(data => {
        if (data.count > 0) {
          const badge = document.getElementById('notifBadge');
          badge.textContent = data.count;
          badge.style.display = 'inline-block';
        }
      });
  </script>
  <% } %>
</body>
</html>