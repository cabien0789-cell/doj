<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= contest.name %> - DOJ</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
</head>
<body>
  <nav class="navbar">
    <div class="nav-left">
      <a href="/" class="logo">DOJ</a>
      <a href="/problems" class="nav-link">Problems</a>
      <a href="/organizations" class="nav-link">Organizations</a>
      <a href="/leaderboard" class="nav-link">Leaderboard</a>
      <% if (user && user.role === 'admin') { %>
        <a href="/admin" class="nav-link">Admin</a>
      <% } %>
    </div>
    <div class="nav-right">
      <% if (user) { %>
        <a href="/notifications" class="notif-btn">
          🔔 <span class="notif-badge" id="notifBadge" style="display:none;">0</span>
        </a>
        <a href="/profile/<%= user.username %>" class="nav-username"><%= user.username %></a>
        <a href="/logout" class="btn-logout">Logout</a>
      <% } else { %>
        <a href="/login" class="btn-login">Log In</a>
        <a href="/register" class="btn-register">Sign Up</a>
      <% } %>
    </div>
  </nav>

  <% if (accessDenied) { %>
    <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; height:calc(100vh - 64px); text-align:center;">
      <div style="font-size:64px; margin-bottom:16px;">🔒</div>
      <h2 style="color:#ffffff; margin-bottom:12px;">Private Contest</h2>
      <p style="color:#7a9ab0; margin-bottom:24px;">This contest is private. Only members of the organization can access it.</p>
      <a href="/organizations" class="btn-hero" style="font-size:15px; padding:10px 28px;">Browse Organizations</a>
    </div>
  <% } else { %>

  <div class="problems-container">
    <div class="org-header">
      <h2><%= contest.name %></h2>
      <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap;">
        <% if (contest.visibility === 'private') { %>
          <span style="background:#f5a62320; color:#f5a623; font-size:12px; padding:4px 12px; border:1px solid #f5a623; border-radius:20px; font-weight:600;">🔒 Private</span>
        <% } else { %>
          <span style="background:#1a2a36; color:#7a9ab0; font-size:12px; padding:4px 12px; border:1px solid #2a3e4e; border-radius:20px;">🌐 Public</span>
        <% } %>
        <% if (contest.noTimeLimit) { %>
          <span class="status-live">● Live</span>
        <% } else { %>
          <% const now = new Date(); %>
          <% if (now < new Date(contest.startTimeUTC)) { %>
            <span class="status-upcoming">Upcoming</span>
          <% } else if (now > new Date(contest.endTimeUTC)) { %>
            <span class="status-ended">Ended</span>
          <% } else { %>
            <span class="status-live">● Live</span>
          <% } %>
        <% } %>
      </div>
    </div>

    <% if (user && isOwner) { %>
      <div style="display:flex; gap:10px; flex-wrap:wrap; margin-bottom:24px;">
        <a href="/contests/<%= contest.id %>/problems/create" class="btn-register" style="text-decoration:none;">+ Add Problem</a>
        <a href="/contests/<%= contest.id %>/edit" style="display:inline-block; text-decoration:none; padding:10px 20px; border:1px solid #f5a623; color:#f5a623; border-radius:4px; font-size:14px;">✏ Edit Contest</a>
        <button onclick="confirmAction('delete-contest-form', 'Are you sure you want to delete this contest? This cannot be undone.')" class="btn-danger">Delete Contest</button>
        <form id="delete-contest-form" action="/contests/<%= contest.id %>/delete" method="POST" style="display:none;"></form>
      </div>
    <% } %>

    <% if (!contest.noTimeLimit) { %>
      <%
        const tzName = contest.timezone === 'Vietnam' ? 'Asia/Ho_Chi_Minh' : 'UTC';
        const startDisplay = new Date(contest.startTimeUTC).toLocaleString('en-GB', { timeZone: tzName, hour12: false });
        const endDisplay = new Date(contest.endTimeUTC).toLocaleString('en-GB', { timeZone: tzName, hour12: false });
      %>
      <div class="org-info">
        <span>Start: <strong><%= startDisplay %></strong></span>
        <span>End: <strong><%= endDisplay %></strong></span>
        <span>Time: <strong><%= contest.timezone === 'Vietnam' ? 'Vietnam (UTC+7)' : 'UTC' %></strong></span>
      </div>
    <% } else { %>
      <div class="org-info">
        <span style="color:#00e5a0; font-weight:600;">No time limit — always open</span>
      </div>
    <% } %>

    <% if (!contest.noTimeLimit) { %>
      <% const nowMs = new Date().getTime(); %>
      <% const startMs = new Date(contest.startTimeUTC).getTime(); %>
      <% const endMs = new Date(contest.endTimeUTC).getTime(); %>
      <% if (nowMs < endMs) { %>
        <div class="contest-timer-box">
          <% if (nowMs < startMs) { %>
            <span style="color:#7a9ab0; font-size:13px;">Contest starts in</span>
          <% } else { %>
            <span style="color:#7a9ab0; font-size:13px;">Time remaining</span>
          <% } %>
          <div class="contest-timer" id="contestTimer">--:--:--</div>
        </div>
      <% } %>
    <% } %>

    <%
      const nowCheck = new Date().getTime();
      const startCheck = contest.noTimeLimit ? null : new Date(contest.startTimeUTC).getTime();
      const endCheck = contest.noTimeLimit ? null : new Date(contest.endTimeUTC).getTime();
      const isPrivileged = isOwner || (user && user.role === 'admin');
      const contestNotStarted = !contest.noTimeLimit && nowCheck < startCheck;
      const contestEnded = !contest.noTimeLimit && nowCheck > endCheck;
    %>

    <% if (!isPrivileged && contestNotStarted) { %>
      <div class="org-section">
        <div style="text-align:center; padding:60px 0; color:#7a9ab0;">
          <div style="font-size:48px; margin-bottom:16px;">⏳</div>
          <p style="font-size:16px; font-weight:600; color:#ffffff; margin-bottom:8px;">Contest has not started yet.</p>
          <p style="font-size:14px;">Problems will be visible once the contest begins.</p>
        </div>
      </div>
    <% } else if (!isPrivileged && contestEnded) { %>
      <div class="org-section">
        <div style="text-align:center; padding:40px 0; color:#7a9ab0;">
          <div style="font-size:48px; margin-bottom:16px;">🏁</div>
          <p style="font-size:16px; font-weight:600; color:#ffffff; margin-bottom:8px;">Contest has ended.</p>
          <p style="font-size:14px;">Problems are no longer available.</p>
        </div>
      </div>

      <div class="org-section">
        <h3>Scoreboard</h3>
        <table class="problems-table">
          <thead>
            <tr>
              <th>Rank</th>
              <th>Username</th>
              <th>Solved</th>
              <th>Last Accepted</th>
            </tr>
          </thead>
          <tbody>
            <% if (scoreboard.length === 0) { %>
              <tr><td colspan="4" class="no-problems">No submissions yet.</td></tr>
            <% } else { %>
              <% scoreboard.forEach((entry, index) => { %>
                <tr>
                  <td>
                    <% if (index === 0) { %><span style="color:#f5c518; font-weight:700; font-size:18px;">🥇</span>
                    <% } else if (index === 1) { %><span style="color:#c0c0c0; font-weight:700; font-size:18px;">🥈</span>
                    <% } else if (index === 2) { %><span style="color:#cd7f32; font-weight:700; font-size:18px;">🥉</span>
                    <% } else { %><%= index + 1 %><% } %>
                  </td>
                  <td><a href="/profile/<%= entry.username %>"><%= entry.username %></a></td>
                  <td style="color:#00e5a0; font-weight:600;"><%= entry.solved %></td>
                  <td style="color:#7a9ab0; font-size:13px;"><%= entry.lastAC ? new Date(entry.lastAC).toLocaleString('en-GB', { hour12: false }) : '—' %></td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="org-section">
        <h3>Problems</h3>
        <table class="problems-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Title</th>
              <th>Difficulty</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% if (problems.length === 0) { %>
              <tr><td colspan="4" class="no-problems">No problems in this contest.</td></tr>
            <% } else { %>
              <% problems.forEach((problem, index) => { %>
                <tr>
                  <td><%= index + 1 %></td>
                  <td><a href="/problems/<%= problem.id %>"><%= problem.title %></a></td>
                  <td class="difficulty-<%= problem.difficulty.toLowerCase() %>"><%= problem.difficulty %></td>
                  <td>
                    <% if (user && userSolvedInContest.includes(problem.id)) { %>
                      <span style="color:#00e5a0; font-weight:600;">✓ Solved</span>
                    <% } else { %>
                      <span style="color:#7a9ab0;">—</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>

      <div class="org-section">
        <h3>Scoreboard</h3>
        <table class="problems-table">
          <thead>
            <tr>
              <th>Rank</th>
              <th>Username</th>
              <th>Solved</th>
              <th>Last Accepted</th>
            </tr>
          </thead>
          <tbody>
            <% if (scoreboard.length === 0) { %>
              <tr><td colspan="4" class="no-problems">No submissions yet.</td></tr>
            <% } else { %>
              <% scoreboard.forEach((entry, index) => { %>
                <tr>
                  <td>
                    <% if (index === 0) { %><span style="color:#f5c518; font-weight:700; font-size:18px;">🥇</span>
                    <% } else if (index === 1) { %><span style="color:#c0c0c0; font-weight:700; font-size:18px;">🥈</span>
                    <% } else if (index === 2) { %><span style="color:#cd7f32; font-weight:700; font-size:18px;">🥉</span>
                    <% } else { %><%= index + 1 %><% } %>
                  </td>
                  <td><a href="/profile/<%= entry.username %>"><%= entry.username %></a></td>
                  <td style="color:#00e5a0; font-weight:600;"><%= entry.solved %></td>
                  <td style="color:#7a9ab0; font-size:13px;"><%= entry.lastAC ? new Date(entry.lastAC).toLocaleString('en-GB', { hour12: false }) : '—' %></td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <% } %>

  <script>
    function confirmAction(formId, message) {
      if (confirm(message)) document.getElementById(formId).submit();
    }

    <% if (!accessDenied && !contest.noTimeLimit) { %>
    const endTime = new Date('<%= contest.endTimeUTC %>').getTime();
    const startTime = new Date('<%= contest.startTimeUTC %>').getTime();
    const timerEl = document.getElementById('contestTimer');

    function updateTimer() {
      if (!timerEl) return;
      const now = Date.now();
      const target = now < startTime ? startTime : endTime;
      const diff = target - now;
      if (diff <= 0) { timerEl.textContent = '00:00:00'; clearInterval(timerInterval); return; }
      const h = Math.floor(diff / 3600000);
      const m = Math.floor((diff % 3600000) / 60000);
      const s = Math.floor((diff % 60000) / 1000);
      timerEl.textContent = String(h).padStart(2,'0') + ':' + String(m).padStart(2,'0') + ':' + String(s).padStart(2,'0');
    }
    updateTimer();
    const timerInterval = setInterval(updateTimer, 1000);
    <% } %>

    <% if (user) { %>
    fetch('/notifications/count').then(r => r.json()).then(data => {
      if (data.count > 0) {
        const badge = document.getElementById('notifBadge');
        badge.textContent = data.count;
        badge.style.display = 'inline-block';
      }
    });
    <% } %>
  </script>
</body>
</html>