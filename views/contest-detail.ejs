<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= contest.name %> - DOJ</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
</head>
<body>
  <nav class="navbar">
    <div class="nav-left">
      <a href="/" class="logo">DOJ</a>
      <a href="/problems" class="nav-link">Problems</a>
      <a href="/organizations" class="nav-link">Organizations</a>
      <a href="/leaderboard" class="nav-link">Leaderboard</a>
    </div>
    <div class="nav-right">
      <% if (user) { %>
        <a href="/problems/create" class="btn-register">+ Create</a>
        <a href="/profile/<%= user.username %>" class="nav-username"><%= user.username %></a>
        <a href="/logout" class="btn-logout">Logout</a>
      <% } else { %>
        <a href="/login" class="btn-login">Log In</a>
        <a href="/register" class="btn-register">Sign Up</a>
      <% } %>
    </div>
  </nav>

  <div class="problems-container">
    <div class="org-header">
      <h2><%= contest.name %></h2>
      <% const now = new Date(); %>
      <% if (now < new Date(contest.startTime)) { %>
        <span class="status-upcoming">Upcoming</span>
      <% } else if (now > new Date(contest.endTime)) { %>
        <span class="status-ended">Ended</span>
      <% } else { %>
        <span class="status-live">● Live</span>
      <% } %>
    </div>

    <div class="org-info">
      <span>Start: <strong><%= new Date(contest.startTime).toLocaleString() %></strong></span>
      <span>End: <strong><%= new Date(contest.endTime).toLocaleString() %></strong></span>
    </div>

    <!-- Timer -->
    <% const nowMs = new Date().getTime(); %>
    <% const startMs = new Date(contest.startTime).getTime(); %>
    <% const endMs = new Date(contest.endTime).getTime(); %>
    <% if (nowMs < endMs) { %>
      <div class="contest-timer-box">
        <% if (nowMs < startMs) { %>
          <span style="color:#a0a0b0; font-size:13px;">Contest starts in</span>
        <% } else { %>
          <span style="color:#a0a0b0; font-size:13px;">Time remaining</span>
        <% } %>
        <div class="contest-timer" id="contestTimer">--:--:--</div>
      </div>
    <% } %>

    <!-- Problems -->
    <div class="org-section">
      <h3>Problems</h3>
      <table class="problems-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Title</th>
            <th>Difficulty</th>
          </tr>
        </thead>
        <tbody>
          <% if (problems.length === 0) { %>
            <tr>
              <td colspan="3" class="no-problems">No problems in this contest.</td>
            </tr>
          <% } else { %>
            <% problems.forEach((problem, index) => { %>
              <tr>
                <td><%= index + 1 %></td>
                <td><a href="/problems/<%= problem.id %>"><%= problem.title %></a></td>
                <td class="difficulty-<%= problem.difficulty.toLowerCase() %>"><%= problem.difficulty %></td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- Scoreboard -->
    <div class="org-section">
      <h3>Scoreboard</h3>
      <table class="problems-table">
        <thead>
          <tr>
            <th>Rank</th>
            <th>Username</th>
            <th>Solved</th>
            <th>Last Accepted</th>
          </tr>
        </thead>
        <tbody>
          <% if (scoreboard.length === 0) { %>
            <tr>
              <td colspan="4" class="no-problems">No submissions yet.</td>
            </tr>
          <% } else { %>
            <% scoreboard.forEach((entry, index) => { %>
              <tr>
                <td>
                  <% if (index === 0) { %>
                    <span style="color:#f5c518; font-weight:700; font-size:18px;">🥇</span>
                  <% } else if (index === 1) { %>
                    <span style="color:#a0a0b0; font-weight:700; font-size:18px;">🥈</span>
                  <% } else if (index === 2) { %>
                    <span style="color:#cd7f32; font-weight:700; font-size:18px;">🥉</span>
                  <% } else { %>
                    <%= index + 1 %>
                  <% } %>
                </td>
                <td><a href="/profile/<%= entry.username %>"><%= entry.username %></a></td>
                <td style="color:#00e5a0; font-weight:600;"><%= entry.solved %></td>
                <td style="color:#a0a0b0; font-size:13px;"><%= entry.lastAC ? new Date(entry.lastAC).toLocaleString() : '—' %></td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <script>
    const endTime = new Date('<%= contest.endTime %>').getTime();
    const startTime = new Date('<%= contest.startTime %>').getTime();
    const timerEl = document.getElementById('contestTimer');

    function updateTimer() {
      if (!timerEl) return;
      const now = Date.now();
      const target = now < startTime ? startTime : endTime;
      const diff = target - now;

      if (diff <= 0) {
        timerEl.textContent = '00:00:00';
        clearInterval(timerInterval);
        return;
      }

      const h = Math.floor(diff / 3600000);
      const m = Math.floor((diff % 3600000) / 60000);
      const s = Math.floor((diff % 60000) / 1000);
      timerEl.textContent =
        String(h).padStart(2, '0') + ':' +
        String(m).padStart(2, '0') + ':' +
        String(s).padStart(2, '0');
    }

    updateTimer();
    const timerInterval = setInterval(updateTimer, 1000);
  </script>
</body>
</html>